@model LaVeguita.Entities.Vehiculo
@{
    ViewData["Title"] = "Registrar Unidad Logística";
}

<div class="row justify-content-center mt-3">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm" style="border-radius:15px;">
            <div class="card-header bg-success text-white p-3" style="border-radius: 15px 15px 0 0;">
                <h5 class="mb-0 fw-bold"><i class="fas fa-plus-circle me-2"></i>Integrar Unidad a la Flota Activa</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Crear" method="post">
                    <div class="text-danger small mb-3" asp-validation-summary="ModelOnly"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Identificador Único (Serial/Patente)</label>
                            <input asp-for="Serial" class="form-control font-monospace" placeholder="Ej: BICI-004 o TRI-202" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">Tipo de Móvil Ecológico</label>
                            <select asp-for="TipoMovil" class="form-select" required>
                                <option value="BICICLETA">Bicicleta (Carga Ligera &lt; 5kg)</option>
                                <option value="TRICICLO">Triciclo (Carga Pesada &gt;= 5kg)</option>
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label small fw-bold text-muted">Capacidad Máxima Permitida (Cubicaje en Kilogramos)</label>
                            <div class="input-group">
                                <input asp-for="CapMaxKg" type="number" class="form-control" placeholder="Ej: 4, 15, 30" min="1" required />
                                <span class="input-group-text bg-light fw-bold text-muted">KG</span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end border-top pt-3 mt-4">
                        <a asp-action="Index" class="btn btn-light border px-4 fw-bold">Cancelar</a>
                        <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm">Guardar Registro</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>