@model IEnumerable<LaVeguita.Entities.Vehiculo>
@{
    ViewData["Title"] = "Monitor de Flota Ecologica";
}

<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h3 class="fw-bold text-dark"><i class="fas fa-truck text-success me-2"></i>Control de Flota Logística</h3>
        <p class="text-muted small mb-0">Gestión de cubicajes y estados de mantenimiento operativo según las reglas del Caso 4.</p>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
        <a asp-action="Crear" class="btn btn-success btn-sm rounded-pill px-3 fw-bold shadow-sm me-2">
            <i class="fas fa-plus me-1"></i> Nuevo Móvil
        </a>
        <a asp-action="RegistrarMantencion" class="btn btn-dark btn-sm rounded-pill px-3 fw-bold shadow-sm">
            <i class="fas fa-wrench text-warning me-1"></i> Enviar a Taller
        </a>
    </div>
</div>

<div class="table-responsive bg-white p-3 rounded-3 shadow-sm border">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th class="text-muted small text-uppercase">ID</th>
                <th class="text-muted small text-uppercase">Tipo de Móvil</th>
                <th class="text-muted small text-uppercase">Identificador / Serial</th>
                <th class="text-muted small text-uppercase text-center">Capacidad Máxima</th>
                <th class="text-muted small text-uppercase text-center">Estado Operativo</th>
                <th class="text-muted small text-uppercase text-end">Kilometraje</th>
                <th class="text-muted small text-uppercase text-center" style="width: 160px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center py-4 text-muted">No se registran vehículos en la base de datos distribuida.</td>
                </tr>
            }
            else
            {
                foreach (var v in Model)
                {
                    <tr>
                        <td class="fw-bold text-secondary">#@v.IdTransporte</td>
                        <td>
                            @if (v.TipoMovil.ToUpper() == "BICICLETA")
                            {
                                <span class="badge bg-light text-success border border-success px-2 py-1"><i class="fas fa-bicycle me-1"></i> BICICLETA</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-primary border border-primary px-2 py-1"><i class="fas fa-truck-pickup me-1"></i> TRICICLO</span>
                            }
                        </td>
                        <td class="font-monospace fw-bold text-dark">@v.Serial</td>
                        <td class="text-center fw-bold">@v.CapMaxKg Kg</td>
                        <td class="text-center">
                            @if (v.Estado.ToUpper() == "DISPONIBLE")
                            {
                                <span class="badge bg-success rounded-pill px-3 py-1">Disponible</span>
                            }
                            else if (v.Estado.ToUpper() == "MANTENCION" || v.Estado.ToUpper() == "TALLER")
                            {
                                <span class="badge bg-danger rounded-pill px-3 py-1">En Taller</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark rounded-pill px-3 py-1">@v.Estado</span>
                            }
                        </td>
                        <td class="text-end text-muted">@v.KmTotal KM</td>

                        <td class="text-center">
                            @if (v.Estado.ToUpper() == "MANTENCION" || v.Estado.ToUpper() == "TALLER")
                            {
                                <form asp-action="HabilitarVehiculo" method="post" onsubmit="return confirmarAlta(this, '@v.Serial')">
                                    <input type="hidden" name="idTransporte" value="@v.IdTransporte" />
                                    <button type="submit" class="btn btn-sm btn-outline-success rounded-pill px-3 fw-bold shadow-sm">
                                        <i class="fas fa-check-circle me-1"></i> Reintegrar
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small text-uppercase fw-semibold" style="font-size: 0.75rem;"><i class="fas fa-minus me-1"></i> Sin acciones</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <!-- SweetAlert2 integrado para alertas corporativas limpias -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // 🚀 FUNCIÓN CLAVE: Decodifica los caracteres raros (tildes) para que se vean bien en la alerta
        function decodeHtml(html) {
        var txt = document.createElement("textarea");
        txt.innerHTML = html;
        return txt.value;
        }

        document.addEventListener("DOMContentLoaded", function () {

        // 🚀 REPARADO: Ahora limpia el mensaje usando decodeHtml
        @if (TempData["ExitoFlota"] != null)
        {
            <text>
                Swal.fire({
                icon: 'success',
                title: 'Operación Exitosa',
                text: decodeHtml('@TempData["ExitoFlota"]'),
                confirmButtonColor: '#2ecc71'
                });
            </text>
        }

        @if (TempData["Error"] != null)
        {
            <text>
                Swal.fire({
                icon: 'error',
                title: 'Restricción Informática',
                text: decodeHtml('@TempData["Error"]'),
                confirmButtonColor: '#e74c3c'
                });
            </text>
        }
        });

        // Intercepta el submit para darle un feedback UX premium al profesor
        function confirmarAlta(form, serial) {
        event.preventDefault();
        Swal.fire({
        title: '¿Confirmar Alta Técnica?',
        text: "El móvil con serial " + serial + " cambiará su estado a DISPONIBLE para la asignación de rutas y despachos.",
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#2ecc71',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Sí, Reintegrar Móvil',
        cancelButtonText: 'Cancelar'
        }).then((result) => {
        if (result.isConfirmed) {
        form.submit();
        }
        });
        return false;
        }
    </script>
}