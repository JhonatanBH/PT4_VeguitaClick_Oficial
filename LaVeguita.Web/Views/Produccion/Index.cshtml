@{
    ViewData["Title"] = "Centro de Mando - Produccion";
}

<div class="container mt-2">
    <!-- Encabezado Principal -->
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
        <div class="d-flex align-items-center">
            <span class="fs-2 me-2">🏭</span>
            <div>
                <h2 class="text-success fw-bold m-0">Planta de Operaciones y Gestion Productiva</h2>
                <small class="text-muted">Modulo del Jefe de Produccion — La VeguitaClick</small>
            </div>
        </div>
        <span class="badge bg-success px-3 py-2 rounded-pill"><i class="fas fa-user-check me-1"></i> Supervisor Activo</span>
    </div>

    <!-- TARJETAS DE INDICADORES RAPIDOS (KPIs) -->
    <div class="row mb-4">
        <div class="col-md-4 mb-2">
            <div class="card border-0 shadow-sm p-3 bg-light border-start border-success border-4" style="border-radius: 12px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-1">Packs Armados Hoy</h6>
                        <h3 class="fw-bold text-dark m-0">@ViewBag.PacksArmadosHoy</h3>
                    </div>
                    <span class="fs-3 text-success">📦</span>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-2">
            <div class="card border-0 shadow-sm p-3 bg-light border-start border-primary border-4" style="border-radius: 12px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-1">Compost Acumulado</h6>
                        <h3 class="fw-bold text-dark m-0">@ViewBag.KilosCompostGenerados Kg</h3>
                    </div>
                    <span class="fs-3 text-primary">♻️</span>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-2">
            <div class="card border-0 shadow-sm p-3 bg-light border-start border-warning border-4" style="border-radius: 12px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-1">Alertas Activas</h6>
                        <h3 class="fw-bold text-warning m-0">@ViewBag.AlertasCriticas</h3>
                    </div>
                    <span class="fs-3 text-warning">⚠️</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- COLUMNA IZQUIERDA: RECOMENDACIONES Y ACCESO DIRECTO -->
        <div class="col-md-6 mb-4">
            <!-- Boton de Revisar Planta -->
            <div class="card border-0 shadow-sm p-4 text-center mb-4 text-white" style="background: linear-gradient(135deg, #198754, #0f5132); border-radius: 15px;">
                <h4 class="fw-bold mb-2">¿Listo para iniciar operaciones?</h4>
                <p class="small opacity-75 mb-4">Supervisa la linea de desinfeccion, clasifica la calidad de la materia prima entrante y gestiona el compostaje ecologico.</p>
                <a href="@Url.Action("ProcesosPlanta", "Produccion")" class="btn btn-light btn-lg rounded-pill fw-bold text-success px-5 shadow-sm">
                    <i class="fas fa-industry me-2"></i> Revisar Planta / Flujos
                </a>
            </div>

            <!-- Recomendaciones de Uso y Protocolos -->
            <div class="card border-0 shadow-sm p-3" style="border-radius: 15px;">
                <div class="card-body">
                    <h5 class="fw-bold text-dark mb-3"><i class="fas fa-shield-halved text-success me-2"></i> Protocolos de Operacion Segura</h5>
                    <div class="d-flex mb-3">
                        <div class="me-3 fs-4 text-success"><i class="fas fa-hand-holding-droplet"></i></div>
                        <div>
                            <h6 class="fw-bold mb-1">Sanitizacion Estricta</h6>
                            <p class="small text-muted m-0">Asegurar la concentracion adecuada de la solucion biodegradable para desinfectar sin alterar la condicion organica.</p>
                        </div>
                    </div>
                    <div class="d-flex mb-3">
                        <div class="me-3 fs-4 text-primary"><i class="fas fa-recycle"></i></div>
                        <div>
                            <h6 class="fw-bold mb-1">Segregacion de Mermas</h6>
                            <p class="small text-muted m-0">Separar inmediatamente residuos vegetales del empaque para evitar la contaminacion cruzada y derivar directo a compostaje.</p>
                        </div>
                    </div>
                    <div class="d-flex">
                        <div class="me-3 fs-4 text-secondary"><i class="fas fa-apple-whole"></i></div>
                        <div>
                            <h6 class="fw-bold mb-1">Criterio Nutricional de Packing</h6>
                            <p class="small text-muted m-0">Respetar las cantidades e ingredientes establecidos en la bitacora de la nutricionista para formatos Soltero, Pareja o Familiar.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- COLUMNA DERECHA: BANDEJA DE REPORTES O PROBLEMAS -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-radius: 15px;">
                <div class="card-body">
                    <h5 class="fw-bold text-dark mb-3"><i class="fas fa-clipboard-list text-danger me-2"></i> Bandeja de Incidencias en Planta</h5>

                    <div class="list-group list-group-flush">
                        <div class="list-group-item px-0 py-3 border-bottom">
                            <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                                <h6 class="fw-bold text-danger m-0"><i class="fas fa-circle-exclamation me-1"></i> Stock Critico Inminente</h6>
                                <small class="text-muted">Hace 10 min</small>
                            </div>
                            <p class="small text-muted mb-2">Quedan menos de 8 cajas de Tomates Organicos en bodega. Peligro de quiebre para el armado del 'Packing Familiar'.</p>
                            <span class="badge bg-light text-danger border border-danger small">Prioridad Alta</span>
                        </div>

                        <div class="list-group-item px-0 py-3 border-bottom">
                            <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                                <h6 class="fw-bold text-warning m-0"><i class="fas fa-triangle-exclamation me-1"></i> Lote Pendiente Clasificacion</h6>
                                <small class="text-muted">Hace 1 hora</small>
                            </div>
                            <p class="small text-muted mb-2">Llego despacho desde el Productor de Melipilla. 200 kg de Lechugas esperando revision de estandares de calidad en la columna de limpieza.</p>
                            <span class="badge bg-light text-warning border border-warning small">Fase de Seleccion</span>
                        </div>

                        <div class="list-group-item px-0 py-3 border-0">
                            <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                                <h6 class="fw-bold text-success m-0"><i class="fas fa-check-double me-1"></i> Retiro de Compost Completado</h6>
                                <small class="text-muted">Ayer</small>
                            </div>
                            <p class="small text-muted mb-0">Se despacharon 15 sacos de compost de 25kg al predio del agricultor local Don Tomas para optimizar los suelos.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        // Monitorea si el servidor envía algún estatus al cargar el Dashboard
        @if (TempData["Mensaje"] != null)
        {
            <text>
            Swal.fire({ icon: 'success', title: 'Notificación', text: '@TempData["Mensaje"]', confirmButtonColor: '#198754' });
            </text>
        }
    </script>
}