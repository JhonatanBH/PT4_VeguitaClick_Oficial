@{
    ViewData["Title"] = "Gestion de Packing Semanal";
}

<div class="container mt-1">
    <!-- Encabezado de Seccion -->
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
        <div class="d-flex align-items-center">
            <span class="fs-2 me-2">📦</span>
            <div>
                <h3 class="text-dark fw-bold m-0">Lineas de Armado y Packing Semanal</h3>
                <small class="text-muted">Formatos validados por el programa de alimentacion estandar de la nutricionista</small>
            </div>
        </div>
        <span class="badge bg-success px-3 py-2 rounded-pill"><i class="fas fa-apple-whole me-1"></i> Control de Calidad</span>
    </div>

    <!-- TARJETAS DE FORMATOS ESTANDAR (NUTRICIONISTA) -->
    <div class="row g-4 mb-4">

        <!-- FORMATO SOLTERO -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 15px;">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="fw-bold text-success m-0">Packing Soltero</h5>
                            <span class="badge bg-light text-success border border-success">1 Integrante</span>
                        </div>
                        <p class="small text-muted mb-3">Diseñado para cubrir las necesidades vitaminicas individuales de la semana de forma balanceada.</p>
                        <h6 class="small fw-bold text-dark border-bottom pb-1 mb-2">Receta de la Nutricionista:</h6>
                        <ul class="small text-muted ps-3 mb-0">
                            <li>1.5 Kg de Manzanas Organicas</li>
                            <li>1.0 Kg de Platanos locales</li>
                            <li>2 Unidades de Lechugas seleccionadas</li>
                            <li>1.5 Kg de Tomates de primera calidad</li>
                        </ul>
                    </div>
                    <button class="btn btn-outline-success btn-sm w-100 rounded-pill fw-bold mt-4" onclick="seleccionarPack('Soltero', 6.0)">
                        <i class="fas fa-box me-1"></i> Seleccionar para Armado
                    </button>
                </div>
            </div>
        </div>

        <!-- FORMATO PAREJA -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 15px;">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="fw-bold text-primary m-0">Packing Pareja</h5>
                            <span class="badge bg-light text-primary border border-primary">2 Integrantes</span>
                        </div>
                        <p class="small text-muted mb-3">Proporcion equilibrada de antioxidantes y fibras esenciales para dos personas adultas.</p>
                        <h6 class="small fw-bold text-dark border-bottom pb-1 mb-2">Receta de la Nutricionista:</h6>
                        <ul class="small text-muted ps-3 mb-0">
                            <li>3.0 Kg de Manzanas Organicas</li>
                            <li>2.0 Kg de Platanos locales</li>
                            <li>4 Unidades de Lechugas seleccionadas</li>
                            <li>3.0 Kg de Tomates de primera calidad</li>
                        </ul>
                    </div>
                    <button class="btn btn-outline-primary btn-sm w-100 rounded-pill fw-bold mt-4" onclick="seleccionarPack('Pareja', 12.0)">
                        <i class="fas fa-box me-1"></i> Seleccionar para Armado
                    </button>
                </div>
            </div>
        </div>

        <!-- FORMATO FAMILIAR -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 15px;">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="fw-bold text-warning m-0" style="color: #b8860b !important;">Packing Familiar</h5>
                            <span class="badge bg-light text-warning border border-warning" style="color: #b8860b !important;">3 o 4 Integrantes</span>
                        </div>
                        <p class="small text-muted mb-3">Formato maximizado para el nucleo del hogar. Aporte completo de verduras de hoja verde y frutas de estacion.</p>
                        <h6 class="small fw-bold text-dark border-bottom pb-1 mb-2">Receta de la Nutricionista:</h6>
                        <ul class="small text-muted ps-3 mb-0">
                            <li>5.0 Kg de Manzanas Organicas</li>
                            <li>4.0 Kg de Platanos locales</li>
                            <li>6 Unidades de Lechugas seleccionadas</li>
                            <li>5.0 Kg de Tomates de primera calidad</li>
                        </ul>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-outline-warning btn-sm w-50 rounded-pill fw-bold" style="color: #b8860b; border-color: #b8860b;" onclick="seleccionarPack('Familiar (3 Int)', 20.0)">
                            Versión 3 Int
                        </button>
                        <button class="btn btn-outline-warning btn-sm w-50 rounded-pill fw-bold" style="color: #b8860b; border-color: #b8860b;" onclick="seleccionarPack('Familiar (4 Int)', 25.0)">
                            Versión 4 Int
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- PANEL OPERATIVO DE EMBALAJE -->
    <div class="row">
        <div class="col-md-12">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 15px; background-color: #fafbfc;">
                <h5 class="fw-bold text-dark mb-3"><i class="fas fa-cog text-secondary me-2"></i>Mesa de Trabajo: Ejecucion de Empaque</h5>

                <div class="row align-items-center">
                    <div class="col-md-4 mb-2">
                        <label class="form-label small fw-bold text-muted mb-1">Formato de Formulario Activo</label>
                        <input type="text" id="txtPackSeleccionado" class="form-control bg-light fw-bold" placeholder="Ningun pack seleccionado" readonly />
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="form-label small fw-bold text-muted mb-1">Peso Neto Estimado (Kg)</label>
                        <input type="text" id="txtPesoPack" class="form-control bg-light fw-bold text-center" placeholder="0.00" readonly />
                    </div>
                    <div class="col-md-2 mb-2">
                        <label class="form-label small fw-bold text-muted mb-1">Cantidad a Armar</label>
                        <input type="number" id="txtCantidadPacks" class="form-control text-center fw-bold" min="1" value="1" />
                    </div>
                    <div class="col-md-3 mb-2 pt-4">
                        <button type="button" id="btnProcesarPacking" class="btn btn-dark w-100 rounded-pill fw-bold shadow-sm" onclick="procesarLotePacking()">
                            <i class="fas fa-dolly me-1"></i> Confirmar Cierre de Caja
                        </button>
                    </div>
                </div>

                <div id="alertPacking" class="alert alert-success d-none mt-3 border-0 shadow-sm" style="border-radius: 10px;">
                    <i class="fas fa-check-circle me-1"></i> <span id="alertPackingMsg">Lote de empaque cerrado con exito.</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function seleccionarPack(nombre, peso) {
            document.getElementById("txtPackSeleccionado").value = "Packing " + nombre;
            document.getElementById("txtPesoPack").value = peso.toFixed(2) + " Kg";
            document.getElementById("alertPacking").classList.add("d-none");
        }

        function procesarLotePacking() {
            const pack = document.getElementById("txtPackSeleccionado").value;
            const cantidad = document.getElementById("txtCantidadPacks").value;

            if (!pack) {
                alert("⚠️ Debe seleccionar un formato de packing semanal de la nutricionista antes de embalar.");
                return;
            }

            if (cantidad <= 0) {
                alert("❌ Ingrese una cantidad valida de cajas a producir.");
                return;
            }

            // Animacion dinamica para simular el cierre de los packs ecologicos
            const btn = document.getElementById("btnProcesarPacking");
            btn.setAttribute("disabled", "disabled");
            btn.innerHTML = `<i class="fas fa-spinner fa-spin me-1"></i> Sellando cajas en planta...`;

            setTimeout(() => {
                btn.removeAttribute("disabled");
                btn.innerHTML = `<i class="fas fa-dolly me-1"></i> Confirmar Cierre de Caja`;

                const msg = document.getElementById("alertPackingMsg");
                msg.innerText = `Se han empaquetado exitosamente ${cantidad} unidades de "${pack}" siguiendo los protocolos de nutricion. Descontado de la materia prima limpia.`;

                document.getElementById("alertPacking").classList.remove("d-none");

                // Limpiar mesa de trabajo
                document.getElementById("txtPackSeleccionado").value = "";
                document.getElementById("txtPesoPack").value = "";
                document.getElementById("txtCantidadPacks").value = 1;
            }, 1500);
        }
    </script>
}