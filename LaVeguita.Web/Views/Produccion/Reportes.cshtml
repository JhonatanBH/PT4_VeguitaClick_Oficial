@{
    ViewData["Title"] = "Módulo de Reportes Corporativos";
}

<div class="container mt-3">
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
        <div class="d-flex align-items-center">
            <span class="fs-2 me-2">📊</span>
            <div>
                <h3 class="text-success fw-bold m-0">Balances y Consultas del Sistema</h3>
                <small class="text-muted">Centro de Inteligencia de Negocios — La VeguitaClick</small>
            </div>
        </div>
        <span class="badge bg-success px-3 py-2 rounded-pill"><i class="fas fa-file-pdf me-1"></i> Formato Documental</span>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 bg-white" style="border-radius: 15px; border-top: 5px solid #198754;">
                <h5 class="fw-bold text-success mb-2"><i class="fas fa-boxes me-2"></i>Gestion de Compra e Inventarios</h5>
                <p class="small text-muted">Muestra el ingreso total de materias primas brutas registradas en romana desglosadas por proveedor agricola.</p>
                <button type="button" class="btn btn-outline-success btn-sm rounded-pill px-4 fw-bold" onclick="generarReporte('Inventarios')">
                    <i class="fas fa-download me-1"></i> Descargar Balance
                </button>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 bg-white" style="border-radius: 15px; border-top: 5px solid #3498db;">
                <h5 class="fw-bold text-primary mb-2"><i class="fas fa-recycle me-2"></i>Gestion de la Produccion y Mermas</h5>
                <p class="small text-muted">Auditoria de kg limpios ingresados y la generacion de sacos de compostaje ecologico para abono.</p>
                <button type="button" class="btn btn-outline-primary btn-sm rounded-pill px-4 fw-bold" onclick="generarReporte('Produccion')">
                    <i class="fas fa-download me-1"></i> Descargar Balance
                </button>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 bg-white" style="border-radius: 15px; border-top: 5px solid #e67e22;">
                <h5 class="fw-bold text-warning mb-2" style="color:#d35400 !important;"><i class="fas fa-shipping-fast me-2"></i>Gestion de Ventas y Despacho</h5>
                <p class="small text-muted">Historico de ordenes comerciales completadas y clasificacion por modalidades de envio Last-Mile.</p>
                <button type="button" class="btn btn-outline-warning btn-sm rounded-pill px-4 fw-bold" style="color:#d35400; border-color:#d35400;" onclick="generarReporte('Despacho')">
                    <i class="fas fa-download me-1"></i> Descargar Balance
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function generarReporte(tipo) {
            // Animación de carga profesional
            Swal.fire({
                title: 'Generando Reporte',
                text: 'Compilando datos historicos desde Oracle Cloud...',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            // Simula la descarga procesando los datos por 2 segundos
            setTimeout(() => {
                Swal.fire({
                    icon: 'success',
                    title: '¡Documento Listo!',
                    text: 'El informe de ' + tipo + ' ha sido procesado de forma correcta sin tildes de compatibilidad.',
                    confirmButtonText: 'Exportar a PDF',
                    confirmButtonColor: '#198754'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Llama al diálogo nativo de impresión limpia para guardarlo como PDF directo
                        window.print();
                    }
                });
            }, 2000);
        }
    </script>
}