@{
    ViewData["Title"] = "Dashboard Gerencial";
}

<div class="container-fluid">
    <div class="header-dashboard mb-4">
        <h1 class="h3 mb-0 text-gray-800">Bienvenido, @ViewBag.NombreUsuario</h1>
        <p class="text-muted">Estado actual de La Veguita Click - Caso 4</p>
    </div>

    <div class="row">
        @* Tarjeta 1: Inventario *@
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2" style="border-left: 5px solid #2ecc71;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Total Inventario</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalProductos Productos</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-boxes fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Tarjeta 2: Stock Crítico *@
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-danger shadow h-100 py-2" style="border-left: 5px solid #e74c3c;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Stock Crítico</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.StockCritico Alertas</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-exclamation-triangle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Tarjeta 3: Logística (Caso 4) *@
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2" style="border-left: 5px solid #3498db;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Despachos en Curso</div>
                            @* Aquí mostramos los pendientes reales de Oracle *@
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.PendientesEntrega Pendientes</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-truck-loading fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        @* Acciones rápidas *@
        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-light d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">Acciones Administrativas</h6>
                    <i class="fas fa-user-shield text-muted"></i>
                </div>
                <div class="card-body">
                    <p>Gestión de datos maestros según reglas de negocio.</p>
                    <div class="d-flex gap-2">
                        <a asp-controller="Productos" asp-action="Index" class="btn btn-success btn-sm">
                            <i class="fas fa-apple-alt me-1"></i> Inventario
                        </a>
                        <a asp-controller="Usuarios" asp-action="Index" class="btn btn-dark btn-sm">
                            <i class="fas fa-users me-1"></i> Usuarios
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        @* Regla N°12 *@
        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-light">
                    <h6 class="m-0 font-weight-bold text-primary">Control de Calidad (Regla 12)</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning border-0 small mb-0">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Recordatorio:</strong> No se permite el uso de tildes en nombres de usuario ni productos para asegurar la compatibilidad con el sistema de búsqueda.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>