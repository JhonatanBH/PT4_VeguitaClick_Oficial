@{
    ViewData["Title"] = "Dashboard Gerencial";
}

<div class="container-fluid">
    <div class="header-dashboard mb-4">
        <h1 class="h3 mb-0 text-gray-800">Bienvenido, @ViewBag.NombreUsuario</h1>
        <p class="text-muted">Estado actual de La Veguita Click - Caso 4</p>
    </div>

    <!-- CARDS DE INDICADORES SUPERIORES -->
    <div class="row">
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2" style="border-left: 5px solid #2ecc71;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Total Inventario</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalProductos Productos</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-boxes fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-danger shadow h-100 py-2" style="border-left: 5px solid #e74c3c;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Stock Critico</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.StockCritico Alertas</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-exclamation-triangle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2" style="border-left: 5px solid #3498db;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Despachos en Curso</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.PendientesEntrega Pendientes</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-truck-loading fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 🚀 NUEVO: BLOQUE REQUERIMIENTO CASO 4 - COPIA DE SEGURIDAD ANUAL -->
    <div class="card border-0 shadow-sm p-4 bg-white mb-4" style="border-radius: 15px; border-left: 5px solid #e74c3c !important;">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h5 class="fw-bold text-dark m-0"><i class="fas fa-database text-danger me-2"></i>Mantenimiento Crítico del Sistema</h5>
                <p class="text-muted small m-0">Generación del respaldo lógico anual de transacciones y optimización de tablas en Oracle Cloud.</p>
            </div>
            <form action="/Produccion/GenerarBackupAnual" method="post" id="formBackup">
                <button type="submit" class="btn btn-danger fw-bold rounded-pill px-4 py-2 shadow-sm">
                    <i class="fas fa-file-download me-2"></i>Ejecutar Copia de Seguridad Anual
                </button>
            </form>
        </div>
    </div>

    <!-- GRÁFICOS DE CONTROL -->
    <div class="row mt-2">
        <div class="col-xl-6 col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-success"><i class="fas fa-chart-pie me-1"></i> Demanda por Modalidad de Envio</h6>
                </div>
                <div class="card-body" style="position: relative; height:300px;">
                    <canvas id="chartModalidad"></canvas>
                </div>
            </div>
        </div>

        <div class="col-xl-6 col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-success"><i class="fas fa-chart-bar me-1"></i> Asignacion de Vehiculos por Cubicaje</h6>
                </div>
                <div class="card-body" style="position: relative; height:300px;">
                    <canvas id="chartFlota"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- ACCIONES ADMINISTRATIVAS Y CONTROL DE CALIDAD -->
    <div class="row mt-2">
        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-light d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">Acciones Administrativas</h6>
                    <i class="fas fa-user-shield text-muted"></i>
                </div>
                <div class="card-body">
                    <p>Gestion de datos maestros segun reglas de negocio.</p>
                    <div class="d-flex gap-2">
                        <a asp-controller="Productos" asp-action="Index" class="btn btn-success btn-sm">
                            <i class="fas fa-apple-alt me-1"></i> Inventario
                        </a>
                        <a asp-controller="Usuarios" asp-action="Index" class="btn btn-dark btn-sm">
                            <i class="fas fa-users me-1"></i> Usuarios
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-light">
                    <h6 class="m-0 font-weight-bold text-primary">Control de Calidad (Regla 12)</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning border-0 small mb-0">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Recordatorio:</strong> No se permite el uso de tildes en nombres de usuario ni productos para asegurar la compatibilidad con el sistema de busqueda.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {

    // Alerta de confirmación visual para el Backup Anual
    const formBackup = document.getElementById("formBackup");
    if(formBackup) {
    formBackup.addEventListener("submit", function(e) {
    Swal.fire({
    icon: 'info',
    title: 'Procesando Respaldo',
    text: 'Conectando con Oracle Cloud y generando el archivo físico de volcado...',
    showConfirmButton: false,
    timer: 3500
    });
    });
    }

    // 1. CONFIGURACION DEL GRAFICO DE MODALIDADES DE ENVIO (PIE)
    const ctxModalidad = document.getElementById('chartModalidad').getContext('2d');
    new Chart(ctxModalidad, {
    type: 'pie',
    data: {
    labels: ['Normal (6h)', 'Economico (Next Day)', 'Urgente (2h)', 'Fijo (Agendado)'],
    datasets: [{
    // 🚀 CORREGIDO: Se agregaron salvaguardas ?? 0 para que JavaScript no crasheé si no hay ventas
    data: [
    @(ViewBag.GraficoNormal ?? 0),
    @(ViewBag.GraficoEconomico ?? 0),
    @(ViewBag.GraficoUrgente ?? 0),
    @(ViewBag.GraficoFijo ?? 0)
    ],
    backgroundColor: ['#3498db', '#f1c40f', '#e74c3c', '#9b59b6'],
    borderWidth: 2
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
    legend: { position: 'bottom' }
    }
    }
    });

    // 2. CONFIGURACION DEL GRAFICO DE RENDIMIENTO DE FLOTA (BAR)
    const ctxFlota = document.getElementById('chartFlota').getContext('2d');
    new Chart(ctxFlota, {
    type: 'bar',
    data: {
    labels: ['Normal (6h)', 'Economico (Next Day)', 'Urgente (2h)', 'Fijo (Agendado)'],
    datasets: [{
    data: [
    @(ViewBag.GraficoNormal ?? 0),
    @(ViewBag.GraficoEconomico ?? 0),
    @(ViewBag.GraficoUrgente ?? 0),
    @(ViewBag.GraficoFijo ?? 0)
    ],
    backgroundColor: ['#3498db', '#f1c40f', '#e74c3c', '#9b59b6'],
    borderWidth: 2
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
    legend: { display: false }
    },
    scales: {
    y: { beginAtZero: true, ticks: { stepSize: 2 } }
    }
    }
    });
    });
</script>