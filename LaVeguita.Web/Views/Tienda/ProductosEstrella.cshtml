@model IEnumerable<LaVeguita.Entities.Producto>
@{
    ViewData["Title"] = "Productos Estrella";
}
<div class="container py-4">
    <div class="text-center mb-5">
        <span style="font-size: 3.5rem;">⭐</span>
        <h2 class="fw-bold text-dark mt-2">Selección de <span class="text-success">Productos Estrella</span></h2>
        <p class="text-muted">Nuestra vitrina de hortalizas exclusivas de Calidad Premium seleccionadas para ti</p>
    </div>

    <div class="row">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center text-muted col-12 py-5">
                <p>No hay productos Premium cargados en la base de datos para hoy.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-3 bg-light" style="border: 1px solid #e2e8f0 !important;">
                        <span class="badge bg-warning text-dark align-self-center rounded-pill px-3 fw-bold mb-2">⭐ PREMIUM</span>
                        <h5 class="fw-bold text-dark mt-2">@item.NomProducto</h5>
                        <p class="text-muted small">@item.Descripcion</p>
                        <span class="h4 fw-bold text-success d-block mt-auto">$@item.PrecioUnd.ToString("N0")</span>
                    </div>
                </div>
            }
        }
    </div>
</div>