@{
    ViewData["Title"] = "Quiénes Somos - La Veguita Click";
}
<div class="container py-4 text-center">
    <span style="font-size: 4rem;">🌿</span>
    <h2 class="fw-bold text-success mt-2">Nuestra Organización</h2>
    <p class="text-muted mx-auto max-w-600 mt-3" style="font-size: 1.1rem;">
        <strong>La VeguitaClick</strong> es un ecosistema tecnológico de comercialización de hortalizas enfocado en el desarrollo local sustentable. Contamos con una infraestructura de 1.000 metros cuadrados acondicionados con la más alta tecnología.
    </p>
    <div class="row justify-content-center gap-4 mt-4">
        <div class="col-md-4 card shadow-sm p-4 border-0 rounded-4 bg-light">
            <h4 class="text-success fw-bold"><i class="fas fa-users"></i> Capital Humano</h4>
            <p class="text-muted m-0 mt-2 small">Plantilla estable de 12 profesionales internos con contrato indefinido y 6 transportistas dedicados.</p>
        </div>
        <div class="col-md-4 card shadow-sm p-4 border-0 rounded-4 bg-light">
            <h4 class="text-success fw-bold"><i class="fas fa-hand-holding-heart"></i> Inclusión Real</h4>
            <p class="text-muted m-0 mt-2 small">Garantizamos espacios adaptados y fomento al desarrollo laboral inclusivo en cada nivel organizativo.</p>
        </div>
    </div>
</div>