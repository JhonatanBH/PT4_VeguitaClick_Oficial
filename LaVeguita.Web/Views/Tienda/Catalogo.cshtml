@model IEnumerable<LaVeguita.Entities.Producto>

@{
    ViewData["Title"] = "Catálogo La Veguita";
}

<style>
    /* Estética de tarjetas modernas */
    .product-card {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
        border-radius: 20px !important;
        background: #fff;
    }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
        }

    /* Contenedor de "Imagen" con Icono */
    .img-placeholder {
        height: 180px;
        background: linear-gradient(135deg, #f9fbfd 0%, #f1f4f8 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        border-bottom: 1px solid #f1f1f1;
    }

    .main-icon {
        font-size: 4.5rem;
        color: #2ecc71;
        filter: drop-shadow(2px 4px 8px rgba(46, 204, 113, 0.2));
    }

    /* Distintivo de Orgánico */
    .badge-organic {
        position: absolute;
        top: 15px;
        left: 15px;
        background: #27ae60;
        color: white;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        box-shadow: 0 4px 10px rgba(39, 174, 96, 0.3);
    }

    .card-title {
        font-weight: 700;
        color: #2c3e50;
    }

    /* Botón flotante de añadir */
    .btn-add {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
        border: none;
        box-shadow: 0 4px 15px rgba(46, 204, 113, 0.3);
    }

        .btn-add:hover {
            background-color: #27ae60 !important;
            transform: scale(1.1);
        }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-5 px-3">
        <div>
            <h1 class="fw-bold text-dark m-0">Mercado <span class="text-success">La Veguita</span></h1>
            <p class="text-muted">Selección premium de frutas y verduras</p>
        </div>
        <a asp-controller="Tienda" asp-action="Carrito" class="btn btn-success btn-lg rounded-pill shadow px-4 fw-bold">
            <i class="fas fa-shopping-basket me-2"></i> Mi Carrito
        </a>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-pill px-4 shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row px-3">
        @foreach (var item in Model)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-4">
                <div class="card product-card h-100 border-0 shadow-sm">
                    
                    <div class="img-placeholder">
                        @if (item.EsOrganico == "S")
                        {
                            <span class="badge-organic"><i class="fas fa-leaf me-1"></i> Orgánico</span>
                        }
                        
                        @* Selección de icono dinámico según el nombre *@
                        @{
                            var iconClass = "fa-apple-whole"; // Default
                            var nom = item.NomProducto.ToLower();
                            if (nom.Contains("papa") || nom.Contains("zanahoria")) iconClass = "fa-carrot";
                            else if (nom.Contains("lechuga") || nom.Contains("acelga")) iconClass = "fa-leaf";
                            else if (nom.Contains("naranja") || nom.Contains("limon")) iconClass = "fa-lemon";
                        }
                        <i class="fas @iconClass main-icon"></i>
                    </div>
                    
                    <div class="card-body d-flex flex-column p-4">
                        <small class="text-success fw-bold text-uppercase" style="font-size: 0.7rem; letter-spacing: 1px;">@item.NomTipo</small>
                        <h5 class="card-title mt-1" title="@item.NomProducto">@item.NomProducto</h5>
                        <p class="text-muted small flex-grow-1">@item.Descripcion</p>
                        
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <div>
                                <span class="d-block text-muted small" style="margin-bottom: -5px;">Precio</span>
                                <span class="h4 fw-bold text-dark m-0">$@item.PrecioUnd.ToString("N0")</span>
                            </div>

                            <form asp-controller="Tienda" asp-action="AgregarAlCarrito" method="post" class="mt-3">
                                <input type="hidden" name="idProducto" value="@item.IdProducto" />
                                <input type="hidden" name="nombre" value="@item.NomProducto" />
                                <input type="hidden" name="precio" value="@item.PrecioUnd" />
                                <input type="hidden" name="peso" value="@item.PesoUnitEstimado" />
    
                                <div class="input-group mb-2">
                                    <span class="input-group-text bg-white">Cant.</span>
                                    <input type="number" name="cantidad" value="1" min="1" max="@item.StockActual" class="form-control text-center">
                                </div>

                                <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold">
                                    <i class="fas fa-cart-plus me-2"></i> Añadir
                                </button>
                            </form>
                        </div>
                    </div>
                    
                    <div class="card-footer bg-white border-0 px-4 pb-4">
                        <div class="d-flex justify-content-between pt-3 border-top text-muted small">
                            <span><i class="fas fa-cubes me-1"></i> Stock: @item.StockActual</span>
                            <span><i class="fas fa-weight-hanging me-1"></i> @item.PesoUnitEstimado kg</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>