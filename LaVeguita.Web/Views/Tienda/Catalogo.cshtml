@model IEnumerable<LaVeguita.Entities.Producto>

@{
    ViewData["Title"] = "Catálogo La Veguita";
}

<style>
    /* Estética de tarjetas e-commerce modernas */
    .product-card {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
        border-radius: 16px !important;
        background: #fff;
        overflow: hidden;
        border: 1px solid #eef2f5 !important;
    }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important;
        }

    /* Contenedor de Imagen Real */
    .img-container {
        height: 200px;
        position: relative;
        background-color: #f8f9fa;
    }

    .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover; /* Ajusta la imagen sin deformarla */
    }

    /* Distintivo de Orgánico */
    .badge-organic {
        position: absolute;
        top: 15px;
        left: 15px;
        background: #27ae60;
        color: white;
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        box-shadow: 0 4px 10px rgba(39, 174, 96, 0.3);
        z-index: 10;
    }

    /* Distintivo de Stock Alerta */
    .badge-stock-alert {
        position: absolute;
        top: 15px;
        right: 15px;
        background: #e74c3c;
        color: white;
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 700;
        z-index: 10;
    }

    .card-title {
        font-weight: 700;
        color: #2c3e50;
        font-size: 1.15rem;
    }

    .unit-text {
        font-size: 0.8rem;
        color: #7f8c8d;
        font-weight: 600;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 px-3">
        <div>
            <h1 class="fw-bold text-dark m-0">Mercado <span class="text-success">La Veguita</span></h1>
            <p class="text-muted">Selección premium de frutas y verduras frescas</p>
        </div>
        <a asp-controller="Tienda" asp-action="Carrito" class="btn btn-success btn-lg rounded-pill shadow px-4 fw-bold">
            <i class="fas fa-shopping-basket me-2"></i> Mi Carrito
        </a>
    </div>

    @if (ViewBag.BusquedaMsg != null)
    {
        <div class="d-flex justify-content-between align-items-center alert alert-info rounded-pill px-4 shadow-sm mb-4 ms-3 me-3">
            <span><i class="fas fa-search me-2"></i> @ViewBag.BusquedaMsg</span>
            <a asp-controller="Tienda" asp-action="Catalogo" class="btn btn-sm btn-secondary rounded-pill px-3">Limpiar Filtro</a>
        </div>
    }


    <div class="row px-3">
        @foreach (var item in Model)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-4">
                <div class="card product-card h-100 border-0 shadow-sm">

                    <div class="img-container">
                        @if (item.EsOrganico == "S")
                        {
                            <span class="badge-organic"><i class="fas fa-leaf me-1"></i> Orgánico</span>
                        }

                        @if (item.StockActual <= item.StockMin)
                        {
                            <span class="badge-stock-alert"><i class="fas fa-exclamation-triangle me-1"></i> ¡Últimas Unidades!</span>
                        }

                        <img src="https://loremflickr.com/400/300/vegetable,fruit?lock=@item.IdProducto"
                             class="product-img"
                             alt="@item.NomProducto"
                             onerror="this.onerror=null; this.src='https://picsum.photos/400/300?random=@item.IdProducto';" />
                    </div>

                    <div class="card-body d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <small class="text-success fw-bold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">@item.NomTipo</small>
                            <span class="unit-text text-uppercase"><i class="fas fa-tag me-1"></i> Por @item.UnidadMedida</span>
                        </div>

                        <h5 class="card-title" title="@item.NomProducto">@item.NomProducto</h5>
                        <p class="text-muted small flex-grow-1 mb-3">@item.Descripcion</p>

                        <div class="pt-3 border-top mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <small class="text-muted d-block" style="font-size: 0.75rem;">Valor Neto</small>
                                    <span class="h3 fw-bold text-dark m-0">$@item.PrecioUnd.ToString("N0")</span>
                                </div>
                                <div class="text-end">
                                    <small class="text-muted d-block" style="font-size: 0.75rem;">Formato Despacho</small>
                                    <span class="badge bg-light text-dark border fw-bold"><i class="fas fa-box me-1 text-muted"></i> @item.Packing</span>
                                </div>
                            </div>

                            <form asp-controller="Tienda" asp-action="AgregarAlCarrito" method="post">
                                <input type="hidden" name="idProducto" value="@item.IdProducto" />
                                <input type="hidden" name="nombre" value="@item.NomProducto" />
                                <input type="hidden" name="precio" value="@item.PrecioUnd" />
                                <input type="hidden" name="peso" value="@item.PesoUnitEstimado" />

                                <div class="input-group mb-2 shadow-sm rounded-pill overflow-hidden" style="border: 1px solid #ced4da;">
                                    <button type="button" class="btn btn-light border-0 fw-bold px-3 btn-bajar" data-id="@item.IdProducto">-</button>

                                    <input type="number" name="cantidad" id="cant-@item.IdProducto" value="1" min="1" max="@item.StockActual" class="form-control border-0 text-center fw-bold bg-white" readonly>

                                    <button type="button" class="btn btn-light border-0 fw-bold px-3 btn-subir" data-id="@item.IdProducto" data-max="@item.StockActual">+</button>
                                </div>

                                <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold py-2 shadow-sm">
                                    <i class="fas fa-cart-plus me-2"></i> Añadir al Pedido
                                </button>
                            </form>
                        </div>
                    </div>

                    <div class="card-footer bg-white border-0 px-4 pb-4 pt-0">
                        <div class="d-flex justify-content-between pt-3 border-top text-muted small fw-bold">
                            <span><i class="fas fa-cubes text-success me-1"></i> Stock Disponible: @item.StockActual</span>
                            <span><i class="fas fa-weight-hanging text-secondary me-1"></i> Peso Ref: @item.PesoUnitEstimado kg</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<button type="button" class="btn btn-success rounded-circle shadow-lg position-fixed" 
        style="bottom: 25px; right: 25px; width: 60px; height: 60px; z-index: 2000; font-size: 1.5rem;"
        data-bs-toggle="modal" data-bs-target="#modalAyudaExpress">
    💬
</button>

<div class="modal fade" id="modalAyudaExpress" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 15px;">
            <div class="modal-header bg-success text-white" style="border-radius: 15px 15px 0 0;">
                <h5 class="modal-title fw-bold"><i class="fas fa-headset me-2"></i>¿Necesitas Ayuda con tu Pedido?</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <p class="small text-muted mb-3">Ingrese sus datos y un Asistente de Ventas lo contactará de inmediato para gestionar su compra.</p>
                
                <div class="mb-2">
                    <label class="form-label small fw-bold text-muted mb-1">Nombre Completo</label>
                    <input type="text" id="txtAyudaNombre" class="form-control" placeholder="Ej: Pedro Pascal" required />
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-6">
                        <label class="form-label small fw-bold text-muted mb-1">RUT (Con guión)</label>
                        <input type="text" id="txtAyudaRut" class="form-control" placeholder="12345678-9" required />
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-bold text-muted mb-1">Teléfono Móvil</label>
                        <input type="number" id="txtAyudaFono" class="form-control" placeholder="912345678" required />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted mb-1">¿Cuál es su consulta?</label>
                    <textarea id="txtAyudaMensaje" class="form-control" rows="3" placeholder="Ej: No me lee el stock de papas..." required></textarea>
                </div>
                
                <button type="button" id="btnEnviarAyuda" class="btn btn-success w-100 rounded-pill fw-bold py-2 shadow-sm">
                    <i class="fas fa-paper-plane me-1"></i> Enviar Solicitud de Soporte
                </button>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            
            @if (TempData["Mensaje"] != null)
            {
                <text>
                Swal.fire({ icon: 'success', title: 'Producto Añadido', text: '@TempData["Mensaje"]', confirmButtonColor: '#198754', timer: 2000 });
                </text>
            }

            document.querySelectorAll(".btn-subir").forEach(boton => {
                boton.addEventListener("click", function () {
                    const id = this.getAttribute("data-id");
                    const maxStock = parseInt(this.getAttribute("data-max"));
                    const input = document.getElementById("cant-" + id);
                    let valorActual = parseInt(input.value);

                    if (valorActual < maxStock) {
                        input.value = valorActual + 1;
                    } else {
                        Swal.fire({ icon: 'info', title: 'Límite de Stock', text: 'La cantidad máxima actual en bodega es de ' + maxStock + ' unidades.', confirmButtonColor: '#2ecc71' });
                    }
                });
            });

            document.querySelectorAll(".btn-bajar").forEach(boton => {
                boton.addEventListener("click", function () {
                    const id = this.getAttribute("data-id");
                    const input = document.getElementById("cant-" + id);
                    let valorActual = parseInt(input.value);
                    if (valorActual > 1) input.value = valorActual - 1;
                });
            });
        });

        // Evento para procesar la Ayuda Flotante
const btnEnviarAyuda = document.getElementById("btnEnviarAyuda");
if (btnEnviarAyuda) {
    btnEnviarAyuda.addEventListener("click", function() {
        const nom = document.getElementById("txtAyudaNombre").value.trim();
        const rut = document.getElementById("txtAyudaRut").value.trim();
        const fono = document.getElementById("txtAyudaFono").value.trim();
        const msg = document.getElementById("txtAyudaMensaje").value.trim();

        if (!nom || !rut || !fono || !msg) {
            Swal.fire({ icon: 'warning', title: 'Campos Vacíos', text: 'Por favor, complete todos los campos para que el asistente pueda contactarlo.', confirmButtonColor: '#198754' });
            return;
        }

        // Deshabilitar temporalmente
        btnEnviarAyuda.setAttribute("disabled", "disabled");

        fetch(`/Tienda/RegistrarSolicitudAyuda?nombre=${encodeURIComponent(nom)}&rut=${encodeURIComponent(rut)}&telefono=${encodeURIComponent(fono)}&mensaje=${encodeURIComponent(msg)}`, {
            method: 'POST'
        })
        .then(r => r.json())
        .then(data => {
            if (data.exito) {
                Swal.fire({ icon: 'success', title: '¡Solicitud Enviada!', text: 'Un asistente de ventas revisará su requerimiento en el panel central.', confirmButtonColor: '#198754' })
                .then(() => {
                    // Cerrar modal y limpiar
                    const modal = bootstrap.Modal.getInstance(document.getElementById('modalAyudaExpress'));
                    modal.hide();
                    document.getElementById("txtAyudaNombre").value = "";
                    document.getElementById("txtAyudaRut").value = "";
                    document.getElementById("txtAyudaFono").value = "";
                    document.getElementById("txtAyudaMensaje").value = "";
                });
            } else {
                Swal.fire({ icon: 'error', title: 'Error', text: data.mensaje, confirmButtonColor: '#d33' });
            }
            btnEnviarAyuda.removeAttribute("disabled");
        });
    });
}



    </script>
}