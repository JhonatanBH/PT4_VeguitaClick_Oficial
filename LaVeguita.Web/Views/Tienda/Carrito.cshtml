@model List<LaVeguita.Entities.CarritoItem>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>¡Error al procesar!</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-4">
    <h2 class="text-success mb-4">🛒 Tu Carrito de Compras</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">Tu carrito está vacío. ¡Ve al catálogo y elige algo rico!</div>
        <a asp-action="Catalogo" class="btn btn-success">Volver al Catálogo</a>
    }
    else
    {
        <div class="row">
            <div class="col-12 mb-4">
                <div class="table-responsive">
                    <table class="table table-hover bg-white shadow-sm" style="border-radius: 10px; overflow: hidden;">
                        <thead class="bg-success text-white">
                            <tr>
                                <th>Producto</th>
                                <th>Precio</th>
                                <th style="width: 100px;">Cant.</th>
                                <th>Peso Subtotal</th>
                                <th>Subtotal</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Nombre</td>
                                    <td>$@item.Precio.ToString("N0")</td>
                                    <td>@item.Cantidad</td>
                                    <td>@item.PesoSubtotal kg</td>
                                    <td>$@item.Subtotal.ToString("N0")</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <a asp-action="AjustarCantidad" asp-route-id="@item.IdProducto" asp-route-cambio="-1" class="btn btn-sm btn-outline-danger shadow-sm">
                                                <i class="fas fa-minus"></i>
                                            </a>
                                            <span class="mx-3 fw-bold">@item.Cantidad</span>
                                            <a asp-action="AjustarCantidad" asp-route-id="@item.IdProducto" asp-route-cambio="1" class="btn btn-sm btn-outline-success shadow-sm">
                                                <i class="fas fa-plus"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-12 col-lg-6 mx-auto">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h4 class="card-title text-center">Resumen de Compra</h4>
                        <hr>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Total Productos:</span>
                            <strong>@Model.Sum(x => x.Cantidad)</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Peso Total:</span>
                            <strong class="text-primary">@Model.Sum(x => x.PesoSubtotal) kg</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span style="font-size: 1.2rem;">Total a Pagar:</span>
                            <strong style="font-size: 1.2rem;" class="text-success">$@Model.Sum(x => x.Subtotal).ToString("N0")</strong>
                        </div>

                        @* Lógica visual del Caso 4 *@
                        <div class="alert @(Model.Sum(x => x.PesoSubtotal) < 5 ? "alert-info" : "alert-warning") text-center">
                            <strong>Logística:</strong>
                            @(Model.Sum(x => x.PesoSubtotal) < 5 ? "Pedido liviano. Se asignará Bicicleta." : "Pedido pesado. Se asignará Triciclo.")
                        </div>

                        <form asp-action="FinalizarCompra" method="post">
                            <button type="submit" class="btn btn-success w-100 fw-bold py-3 shadow">
                                ✅ Confirmar y Generar Orden
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>