@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    int? rol = HttpContextAccessor.HttpContext.Session.GetInt32("RolUsuario");
    string nombreUser = HttpContextAccessor.HttpContext.Session.GetString("UsuarioNombre") ?? "Invitado";

    // 🚀 CONTROLADOR DE VISTAS PÚBLICAS: Solo Clientes (8) e Invitados (9 o sin sesión activa) ven la tienda
    bool esTiendaPublica = (rol == 8 || rol == 9 || rol == null);
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - La Veguita Click</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
            body {
                margin: 0;
                font-family: 'Segoe UI', sans-serif;
                display: block;
                background-color: #f4f7f6;
                min-height: 100vh;
                overflow-x: hidden;
            }

            .sidebar {
                width: 260px;
                background-color: #2c3e50;
                color: white;
                position: fixed;
                height: 100vh;
                padding: 20px;
                box-sizing: border-box;
                transition: all 0.3s ease;
                left: 0;
                z-index: 1000;
                box-shadow: 4px 0 10px rgba(0,0,0,0.1);
                overflow-y: auto;
            }

                .sidebar.collapsed {
                    left: -260px;
                }

                .sidebar::-webkit-scrollbar {
                    width: 5px;
                }

                .sidebar::-webkit-scrollbar-thumb {
                    background-color: #34495e;
                    border-radius: 10px;
                }

                /* 🌿 LOGO PRINCIPAL: AJUSTADO A VERDE NATURAL */
                .sidebar h2 {
                    color: #2ecc71 !important;
                    text-align: center;
                    font-size: 22px;
                    margin-bottom: 30px;
                    font-weight: bold;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    box-sizing: border-box;
                }

            /* 🌿 PANEL DE STATUS: BORDE VERDE AMBIENTAL */
            .admin-status {
                background: #34495e;
                padding: 15px;
                border-radius: 12px;
                margin-bottom: 25px;
                text-align: center;
                border-left: 5px solid #2ecc71 !important;
            }

            .sidebar ul {
                list-style: none;
                padding: 0;
            }

                .sidebar ul li {
                    margin-bottom: 5px;
                }

                    /* 📝 ENLACES: BLANCO PURO ALALTA LEGIBILIDAD */
                    .sidebar ul li a {
                        color: #ffffff !important;
                        text-decoration: none !important;
                        display: flex;
                        align-items: center;
                        padding: 12px;
                        border-radius: 8px;
                        transition: 0.3s;
                        font-size: 15px;
                        font-weight: 500;
                    }

                        .sidebar ul li a i {
                            width: 25px;
                            margin-right: 10px;
                            font-size: 18px;
                            text-align: center;
                        }

                        /* 🌿 HOVER DE ENLACES: CAMBIADO A VERDE AMBIENTAL */
                        .sidebar ul li a:hover {
                            background: #34495e;
                            color: #2ecc71 !important;
                            padding-left: 20px;
                        }

            /* 🌿 SUBTÍTULOS DE CATEGORÍA LOGÍSTICA */
            .sidebar .menu-header-eco {
                color: #2ecc71 !important;
                font-size: 11px;
                letter-spacing: 1px;
                font-weight: bold;
                text-transform: uppercase;
                margin-top: 25px;
                margin-bottom: 10px;
                padding-left: 12px;
                display: block;
                border-bottom: 1px dashed rgba(46, 204, 113, 0.2);
                padding-bottom: 5px;
            }

            .main-content {
                margin-left: 260px;
                padding: 20px 30px;
                min-height: 100vh;
                transition: all 0.3s ease;
                display: flex;
                flex-direction: column;
            }

                .main-content.expanded {
                    margin-left: 0;
                }

            .top-navbar {
                background: white;
                padding: 12px 25px;
                border-radius: 15px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.03);
                margin-bottom: -15px;
                margin-top: 15px;
            }

            .container-card {
                background: white;
                padding: 25px;
                border-radius: 15px;
                box-shadow: 0 4px 20px rgba(0,0,0,0.05);
                min-height: 75vh;
                flex-grow: 1;
                transition: margin-top 0.3s ease;
            }

            .espacio-tienda {
                margin-top: 35px;
            }

            .espacio-admin {
                margin-top: 55px;
            }

            /* 🌿 BOTÓN FLOTANTE MENÚ */
            .toggle-btn {
                position: fixed;
                top: 25px;
                left: 15px;
                z-index: 1100;
                background: #2ecc71;
                color: white;
                border: none;
                padding: 10px 15px;
                border-radius: 8px;
                cursor: pointer;
                box-shadow: 0 4px 10px rgba(46, 204, 113, 0.3);
                transition: 0.3s;
                font-weight: bold;
            }

                .toggle-btn:hover {
                    background: #27ae60;
                    transform: scale(1.05);
                }

            input::-webkit-outer-spin-button,
            input::-webkit-inner-spin-button {
                -webkit-appearance: none;
                margin: 0;
            }

            input[type=number] {
                -moz-appearance: textfield;
            }

            .veguita-footer {
                background: #2c3e50;
                color: white;
                border-radius: 15px;
                padding: 25px;
                margin-top: 30px;
            }

                .veguita-footer a {
                    color: #2ecc71;
                    transition: 0.3s;
                }

                    .veguita-footer a:hover {
                        color: white;
                    }
    </style>
</head>
<body>

    <button class="toggle-btn" onclick="toggleSidebar()">
        <i class="fas fa-bars"></i>
    </button>

    <nav class="sidebar" id="sidebar">
        <h2 class="mt-4"><i class="fas fa-leaf me-2"></i>La Veguita</h2>

        <div class="admin-status">
            <span style="font-size: 10px; color: #bdc3c7; display: block; text-transform: uppercase;">Sesión Activa</span>
            <strong class="d-block text-white">@nombreUser</strong>
            <span class="badge bg-dark text-white mt-2" style="font-size: 11px; border: 1px solid #2ecc71;">
                @switch (rol)
                {
                    case 1:
                        <span>GERENTE</span>
                        break;
                    case 2:

                        <span>ADMINISTRACIÓN</span>
                        break;
                    case 3:

                        <span>PRODUCCIÓN</span>
                        break;
                    case 4:

                        <span>COMPRAS</span>
                        break;
                    case 5:

                        <span>VENTAS</span>
                        break;
                    case 6:

                        <span>DESPACHO</span>
                        break;
                    case 7:

                        <span>TRANSPORTISTA</span>
                        break;
                    case 8:

                        <span>CLIENTE</span>
                        break;
                    default:

                        <span>INVITADO</span>
                        break;
                }
            </span>
        </div>

        <ul class="mb-5 pb-4">
            <li>
                @if (rol == 1 || rol == 2)
                {
                    <a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Inicio</a>
                }
                else if (rol == 3)
                {
                    <a asp-controller="Produccion" asp-action="Index"><i class="fas fa-home"></i> Inicio</a>
                }
                else if (rol == 5)
                {
                    <a asp-controller="Ventas" asp-action="AsistenteVentas"><i class="fas fa-home"></i> Inicio</a>
                }
                else if (rol == 6)
                {
                    <a asp-controller="Bodega" asp-action="Monitor"><i class="fas fa-home"></i> Inicio</a>
                }
                else if (rol == 7)
                {
                    <a asp-controller="Transporte" asp-action="MisDespachos"><i class="fas fa-home"></i> Inicio</a>
                }
                else
                {
                    <a asp-controller="Tienda" asp-action="Catalogo"><i class="fas fa-home"></i> Inicio</a>
                }
            </li>

            @if (rol >= 1 && rol <= 6)
            {
                <span class="menu-header-eco">Gestión Interna</span>

                <li>
                    <a asp-controller="Ventas" asp-action="BandejaSoporte" class="position-relative">
                        <i class="fas fa-envelope"></i> Mensajería Interna
                        <span id="badgeMensajes" class="badge rounded-pill bg-danger position-absolute end-0 me-5 d-none">0</span>
                        <span id="badgeInterno" class="badge rounded-pill bg-warning text-dark position-absolute end-0 me-2 d-none">0</span>
                    </a>
                </li>

                @if (rol == 1 || rol == 2)
                {
                    <li><a asp-controller="Usuarios" asp-action="Index"><i class="fas fa-users"></i> Gestión Usuarios</a></li>
                    <li><a asp-controller="Empleados" asp-action="Index"><i class="fas fa-id-card"></i> Gestión Empleados</a></li>
                }

                @if (rol == 1 || rol == 2 || rol == 4)
                {
                    <li><a asp-controller="Compras" asp-action="Index"><i class="fas fa-truck-ramp-box"></i> Recepcion Romana</a></li>
                }

                @if (rol == 1 || rol == 2 || rol == 3 || rol == 4 || rol == 5)
                {
                    <li><a asp-controller="Productos" asp-action="Index"><i class="fas fa-boxes-stacked"></i> Inventario global</a></li>
                }

                @if (rol == 1 || rol == 2 || rol == 3)
                {
                    <span class="menu-header-eco">Módulo Operaciones</span>
                    <li><a asp-controller="Produccion" asp-action="Index"><i class="fas fa-chart-pie"></i> Control de Mando</a></li>
                    <li><a asp-controller="Produccion" asp-action="ProcesosPlanta"><i class="fas fa-industry"></i> Revisión de Planta</a></li>
                    <li><a asp-controller="Produccion" asp-action="Packing"><i class="fas fa-box-open"></i> Área de Packing</a></li>
                    <li><a asp-controller="Produccion" asp-action="Reportes"><i class="fas fa-file-invoice"></i> Generación Reportes</a></li>
                }

                @if (rol == 1 || rol == 2 || rol == 5)
                {
                    <li><a asp-controller="Ventas" asp-action="AsistenteVentas"><i class="fas fa-cash-register"></i> Asistente de Ventas</a></li>
                }

                @if (rol == 1 || rol == 6)
                {
                    <li><a asp-controller="Bodega" asp-action="Monitor"><i class="fas fa-box"></i> Preparación en Bodega</a></li>
                    <li><a asp-controller="Logistica" asp-action="GestionLogistica"><i class="fas fa-clipboard-list"></i> Asignación de Despachos</a></li>
                    <li><a asp-controller="Vehiculos" asp-action="Index"><i class="fas fa-truck"></i> Control de Flota</a></li>
                }
            }
            else if (rol == 7)
            {
                <span class="menu-header-eco">Logística</span>
                <li><a asp-controller="Transporte" asp-action="MisDespachos"><i class="fas fa-truck-loading"></i> Hoja de Ruta</a></li>
            }
            else if (esTiendaPublica)
            {
                <span class="menu-header-eco">Mi Tienda</span>
                <li><a asp-controller="Tienda" asp-action="Catalogo"><i class="fas fa-store"></i> Comprar</a></li>
                <li><a asp-controller="Tienda" asp-action="Carrito"><i class="fas fa-shopping-cart"></i> Mi Carrito</a></li>
                <li><a asp-controller="Tienda" asp-action="Seguimiento"><i class="fas fa-truck-ramp-box"></i> Estado de mi Envío</a></li>

                @if (rol == 8)
                {
                    <li><a asp-controller="Tienda" asp-action="Historial"><i class="fas fa-receipt"></i> Mis Pedidos</a></li>
                }
            }

            <li class="mt-4 pt-3" style="border-top: 1px solid #34495e;">
                @if (rol == 9 || rol == null)
                {
                    <a asp-controller="Acceso" asp-action="Login" style="color: #2ecc71 !important; text-decoration: none; display: flex; align-items: center; padding: 12px;">
                        <i class="fas fa-sign-in-alt" style="width: 25px; margin-right: 10px; font-size: 18px;"></i> Iniciar Sesión
                    </a>
                }
                else
                {
                    <a asp-controller="Acceso" asp-action="Logout" style="color: #e74c3c !important; text-decoration: none; display: flex; align-items: center; padding: 12px;">
                        <i class="fas fa-power-off" style="width: 25px; margin-right: 10px; font-size: 18px;"></i> Cerrar Sesión
                    </a>
                }
            </li>
        </ul>
    </nav>

    <main class="main-content" id="main-content">

        @if (esTiendaPublica)
        {
            <div class="top-navbar d-flex justify-content-between align-items-center ms-4">
                <div class="d-flex align-items-center flex-grow-1 max-w-500">
                    <form asp-controller="Tienda" asp-action="Catalogo" method="get" class="w-100 d-flex gap-2">
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-search text-muted"></i></span>
                            <input type="text" name="buscar" value="@Context.Request.Query["buscar"]" class="form-control bg-light border-0" placeholder="Buscar frutas, verduras u orgánicos...">
                            <button type="submit" class="btn btn-success fw-bold px-3">Buscar</button>
                        </div>
                    </form>
                </div>

                <div class="d-flex align-items-center gap-4 ms-3">
                    <a asp-controller="Tienda" asp-action="QuienesSomos" class="text-decoration-none text-secondary small fw-bold"><i class="fas fa-info-circle text-success me-1"></i> ¿Quiénes Somos?</a>
                    <a asp-controller="Tienda" asp-action="ProductosEstrella" class="text-decoration-none text-secondary small fw-bold"><i class="fas fa-star text-warning me-1"></i> Productos Estrella</a>
                </div>
            </div>
        }

        <div class="container-card shadow-sm ms-4 @(esTiendaPublica ? "espacio-tienda" : "espacio-admin")">
            @RenderBody()
        </div>

        @if (esTiendaPublica)
        {
            <div class="veguita-footer ms-4 d-flex justify-content-between align-items-center">
                <div>
                    <span class="fw-bold text-white d-block">Mercado Digital La VeguitaClick</span>
                    <span class="text-white opacity-75 small">© 2026 Duoc UC - Proyecto de Portafolio de Título</span>
                </div>
                <div class="d-flex gap-4 fs-5">
                    <a href="#" onclick="alert('Síguenos en Facebook: @@LaVeguitaClick')"><i class="fab fa-facebook"></i></a>
                    <a href="#" onclick="alert('Síguenos en Instagram: @@LaVeguitaClick')"><i class="fab fa-instagram"></i></a>
                    <a href="#" onclick="alert('Contacto Directo WhatsApp Soporte')"><i class="fab fa-whatsapp"></i></a>
                </div>
            </div>
        }
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('main-content');
        if(sidebar && mainContent) {
        sidebar.classList.toggle('collapsed');
        sidebar.classList.contains('collapsed') ? mainContent.style.marginLeft = "0" : mainContent.style.marginLeft = "260px";
        }
        }

        document.addEventListener("DOMContentLoaded", function () {
        const badge = document.getElementById("badgeMensajes");
        const badgeInterno = document.getElementById("badgeInterno");

        function verificarSoporte() {
        if (badge) {
        fetch('/Ventas/ContarMensajesSoporte')
        .then(r => r.json())
        .then(data => {
        if (data.count > 0) {
        badge.innerText = data.count;
        badge.classList.remove("d-none");
        } else {
        badge.classList.add("d-none");
        }
        })
        .catch(() => {});
        }

        if (badgeInterno) {
        fetch('/Ventas/ContarMensajesInternos')
        .then(r => r.json())
        .then(data => {
        if (data.count > 0) {
        badgeInterno.innerText = data.count;
        badgeInterno.classList.remove("d-none");
        } else {
        badgeInterno.classList.add("d-none");
        }
        })
        .catch(() => {});
        }
        }

        verificarSoporte();
        setInterval(verificarSoporte, 15000);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>