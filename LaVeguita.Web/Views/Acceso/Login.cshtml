@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - La VeguitaClick</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
            body {
                background-color: #f8f9fa;
                display: flex;
                align-items: center;
                height: 100vh;
            }

            .login-card {
                max-width: 400px;
                margin: auto;
                padding: 30px;
                box-shadow: 0 10px 25px rgba(0,0,0,0.08);
                background: white;
                border-radius: 15px;
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="login-card">
            <div class="text-center mb-4">
                <a href="@Url.Action("Catalogo", "Tienda")" class="text-decoration-none d-inline-block">
                    <h2 class="text-success fw-bold m-0"><i class="fas fa-home me-2"></i>La VeguitaClick</h2>
                    <small class="text-muted d-block mt-1">← Volver al Catálogo Público</small>
                </a>
            </div>

            @if (TempData["ExitoRegistro"] != null)
            {
                <div class="alert alert-success small py-2 rounded-3 text-center mb-3">
                    ✅ @TempData["ExitoRegistro"]
                </div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger small py-2 rounded-3 text-center mb-3">
                    ❌ @ViewBag.Error
                </div>
            }

            @if (ViewBag.MostrarRecuperar == true)
            {
                <div class="d-grid mb-3">
                    <button type="button" onclick="alert('Sistema: Se ha enviado un token de restauracion de contrasena a los canales registrados del usuario.')" class="btn btn-outline-danger btn-sm fw-bold rounded-pill py-2">
                        🔑 Olvidaste tu contrasena? Recuperar Aqui
                    </button>
                </div>
            }

            <form id="loginForm" asp-action="Login" asp-controller="Acceso" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">Nombre de Usuario</label>
                    <input type="text" name="user" class="form-control" id="txtUser" placeholder="Ej: admin_veguita" style="padding: 10px;" />
                    <div class="invalid-feedback">El nombre de usuario es obligatorio.</div>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold text-muted small">Contrasena</label>
                    <input type="password" name="pass" class="form-control" id="txtPass" placeholder="Ingrese su clave" style="padding: 10px;" />
                    <div class="invalid-feedback">La contrasena es obligatoria.</div>
                </div>

                <button type="submit" class="btn btn-success w-100 fw-bold py-2.5 rounded-pill shadow-sm">
                    Entrar al Sistema
                </button>
            </form>

            <div class="text-center mt-4 border-top pt-3">
                <a asp-controller="Acceso" asp-action="Registrar" class="text-decoration-none small text-success fw-bold">
                    📝 No tienes cuenta? Registrate como Cliente aqui
                </a>
            </div>

            <p class="text-muted text-center mt-3 mb-0" style="font-size: 0.75rem;">
                Recuerde no utilizar tildes al ingresar sus datos.
            </p>
        </div>
    </div>

    <script>
            document.addEventListener("DOMContentLoaded", function() {
                const formulario = document.getElementById("loginForm");
                const inputs = formulario.querySelectorAll("input");

                inputs.forEach(input => {
                    input.addEventListener("input", function() {
                        validarCampo(this);
                    });
                });

                function validarCampo(campo) {
                    if (campo.value.trim() === "") {
                        campo.classList.add("is-invalid");
                        campo.classList.remove("is-valid");
                        return false;
                    } else {
                        campo.classList.remove("is-invalid");
                        campo.classList.add("is-valid");
                        return true;
                    }
                }

                formulario.addEventListener("submit", function(e) {
                    let formValido = true;

                    inputs.forEach(input => {
                        if (!validarCampo(input)) {
                            formValido = false;
                        }
                    });

                    if (!formValido) {
                        e.preventDefault();
                        // CAMBIO: Alerta profesional sin el link de Azure
                        Swal.fire({
                            icon: 'warning',
                            title: 'Campos incompletos',
                            text: 'Por favor, complete los campos de usuario y contraseña.',
                            confirmButtonColor: '#198754'
                        });
                    }
                });
            });
    </script></body>
</html>