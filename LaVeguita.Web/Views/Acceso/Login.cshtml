@{
    Layout = null; // Para que no cargue el menú de arriba antes de loguearse
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - La VeguitaClick</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #f8f9fa; display: flex; align-items: center; height: 100vh; }
        .login-card { max-width: 400px; margin: auto; padding: 20px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); background: white; border-radius: 10px; }
    </style>
</head>
<body>

<div class="container">
    <div class="login-card">
        <h2 class="text-center mb-4">La VeguitaClick</h2>
        
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form id="loginForm" asp-action="Login" asp-controller="Acceso" method="post">
            <div class="mb-3">
                <label class="form-label">Nombre de Usuario</label>
                <input type="text" name="user" class="form-control" id="txtUser" placeholder="Ej: admin_veguita" />
                <div class="invalid-feedback">El nombre de usuario es obligatorio.</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input type="password" name="pass" class="form-control" id="txtPass" />
                <div class="invalid-feedback">La contraseña es obligatoria.</div>
            </div>
            <button type="submit" class="btn btn-success w-100">Entrar al Sistema</button>
        </form>
        
        <p class="text-muted text-center mt-3" style="font-size: 0.8rem;">
            Recuerde no utilizar tildes al ingresar sus datos.
        </p>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const formulario = document.getElementById("loginForm");
        const inputs = formulario.querySelectorAll("input");

        // 1. Validación en tiempo real (Evento 'input')
        inputs.forEach(input => {
            input.addEventListener("input", function() {
                validarCampo(this);
            });
        });

        // 2. Función que marca en rojo o verde
        function validarCampo(campo) {
            if (campo.value.trim() === "") {
                campo.classList.add("is-invalid"); // Borde rojo de Bootstrap
                campo.classList.remove("is-valid");
                return false;
            } else {
                campo.classList.remove("is-invalid");
                campo.classList.add("is-valid"); // Borde verde si está OK
                return true;
            }
        }

        // 3. Validación final antes de enviar
        formulario.addEventListener("submit", function(e) {
            let formValido = true;
            
            inputs.forEach(input => {
                if (!validarCampo(input)) {
                    formValido = false;
                }
            });

            if (!formValido) {
                e.preventDefault(); // Detiene el envío del formulario
                alert("Por favor, complete los campos obligatorios.");
            }
        });
    });
</script>




</body>
</html>