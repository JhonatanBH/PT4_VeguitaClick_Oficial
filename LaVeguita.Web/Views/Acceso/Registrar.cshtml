@model LaVeguita.Entities.Usuario
@{
    ViewData["Title"] = "Crear Cuenta - La Veguita";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro de Clientes - La VeguitaClick</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
            body {
                display: flex;
                align-items: center;
                min-height: 100vh;
            }

            input::-webkit-outer-spin-button, input::-webkit-inner-spin-button {
                -webkit-appearance: none;
                margin: 0;
            }

            input[type=number] {
                -moz-appearance: textfield;
            }
    </style>
</head>
<body class="bg-light">

    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-12 col-md-6 col-lg-5">
                <div class="mb-3 text-start">
                    <a href="@Url.Action("Catalogo", "Tienda")" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                        <i class="fas fa-arrow-left me-1"></i> Cancelar y Volver al Catálogo
                    </a>
                </div>

                <div class="card border-0 shadow-lg p-3" style="border-radius: 20px;">
                    <div class="card-body">

                        <div class="text-center mb-4">
                            <span class="fs-1">🌿</span>
                            <h3 class="fw-bold text-success mt-2">Unete a La VeguitaClick</h3>
                            <p class="text-muted small">Crea tu cuenta de Cliente para acceder al catalogo ecologico</p>
                        </div>

                        @if (ViewData["Error"] != null)
                        {
                            <div class="alert alert-danger small py-2 rounded-3"><i class="fas fa-exclamation-circle me-1"></i> @ViewData["Error"]</div>
                        }

                        <form asp-action="Registrar" method="post" id="formRegistro">

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Nombre de Usuario (Sin Tildes)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted"><i class="far fa-user"></i></span>
                                    <input asp-for="NombreUser" class="form-control" placeholder="Ej: juan.perez" oninput="cleanInput(this)" required />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Correo Electronico</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted"><i class="far fa-envelope"></i></span>
                                    <input asp-for="CorreoUsu" type="email" class="form-control" placeholder="juan@correo.com" required />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Telefono de Contacto</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted"><i class="fas fa-phone"></i></span>
                                    <input asp-for="Fono" type="number" inputmode="numeric" pattern="[0-9]*" class="form-control" placeholder="Ej: 912345678" required />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Contrasena de Acceso</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted"><i class="fas fa-lock"></i></span>
                                    <input asp-for="Contrasena" type="password" id="txtClave" class="form-control" placeholder="Ingrese su clave" required />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Confirmar Contrasena</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted"><i class="fas fa-shield-alt"></i></span>
                                    <input type="password" name="confirmarPass" id="txtConfirmar" class="form-control" placeholder="Repita su clave" required />
                                </div>
                                <div id="mensajeError" class="text-danger small mt-1 d-none">❌ Las contrasenas no coinciden.</div>
                            </div>
                            <div class="mb-3 p-3 rounded-3" style="background-color: #f8f9fa; border: 1px solid #e9ecef;">
                                <label class="form-label small fw-bold text-muted"><i class="fas fa-map-marker-alt text-danger me-1"></i> Dirección de Despacho (Sin Tildes)</label>

                                <input type="text" name="calleDir" class="form-control mb-2" placeholder="Ej: Av Grecia" oninput="cleanInput(this)" required />

                                <div class="row">
                                    <div class="col-4">
                                        <input type="number" name="numeroDir" class="form-control" placeholder="N°" required />
                                    </div>
                                    <div class="col-8">
                                        <select name="idComunaDir" class="form-select" required>
                                            <option value="">Seleccione Comuna...</option>
                                            <option value="1">Peñalolén</option>
                                            <option value="2">Ñuñoa</option>
                                            <option value="3">Macul</option>
                                            <option value="4">La Reina</option>
                                            <option value="5">Providencia</option>
                                            <option value="6">Santiago Centro</option>
                                            <option value="7">Maipú</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" id="btnEnviar" class="btn btn-success w-100 fw-bold py-2.5 rounded-pill shadow mt-3" disabled>
                                <i class="fas fa-user-plus me-1"></i> Registrarme Ahora
                            </button>

                            <div class="text-center mt-4">
                                <a asp-action="Login" class="text-decoration-none small text-muted">¿Ya tienes cuenta? <span class="text-success fw-bold">Inicia Sesion</span></a>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // 🛡️ MOTOR DE SANITIZACIÓN: Elimina tildes en tiempo real
        function cleanInput(e) {
        e.value = e.value.normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-zA-Z0-9\s-]/g, "");
        }

        document.addEventListener("DOMContentLoaded", function () {
        const txtClave = document.getElementById("txtClave");
        const txtConfirmar = document.getElementById("txtConfirmar");
        const mensajeError = document.getElementById("mensajeError");
        const btnEnviar = document.getElementById("btnEnviar");
        const form = document.getElementById("formRegistro");
        const inputs = form.querySelectorAll('input[required], select[required]');

        function checkFormValidity() {
        let isValid = true;
        inputs.forEach(input => {
        if (!input.value.trim()) isValid = false;
        });

        if (txtClave.value !== txtConfirmar.value) isValid = false;

        btnEnviar.disabled = !isValid;
        }

        function evaluarSimetriaClaves() {
        if (txtConfirmar.value === "") {
        mensajeError.classList.add("d-none");
        checkFormValidity();
        return;
        }

        if (txtClave.value !== txtConfirmar.value) {
        mensajeError.classList.remove("d-none");
        txtConfirmar.classList.add("is-invalid");
        txtConfirmar.classList.remove("is-valid");
        } else {
        mensajeError.classList.add("d-none");
        txtConfirmar.classList.remove("is-invalid");
        txtConfirmar.classList.add("is-valid");
        }
        checkFormValidity();
        }

        inputs.forEach(input => {
        input.addEventListener("input", checkFormValidity);
        input.addEventListener("change", checkFormValidity);
        });

        txtConfirmar.addEventListener("input", evaluarSimetriaClaves);
        txtClave.addEventListener("input", evaluarSimetriaClaves);

        form.addEventListener("submit", function (e) {
        if (txtClave.value !== txtConfirmar.value) {
        e.preventDefault();
        Swal.fire({
        icon: 'error',
        title: 'Error de validación',
        text: 'Las contraseñas no coinciden. Por favor verifíquelas.',
        confirmButtonColor: '#198754'
        });
        }
        });
        });
    </script>
</body>
</html>