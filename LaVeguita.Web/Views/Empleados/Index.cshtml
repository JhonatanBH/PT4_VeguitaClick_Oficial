@model IEnumerable<LaVeguita.Entities.Empleado>

@{
    ViewData["Title"] = "Fichas de Personal";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-0">
                <i class="fas fa-id-card text-primary me-2"></i>Gestión de Capital Humano
            </h2>
            <p class="text-muted">Registro de contratos vigentes y personal de La VeguitaClick</p>
        </div>
        <a asp-controller="Empleados" asp-action="Crear" class="btn btn-primary px-4 fw-bold shadow-sm" style="background-color: #3498db; border: none; border-radius: 8px;">
            <i class="fas fa-user-plus me-1"></i> Registrar Contratación
        </a>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm" style="border-radius: 15px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Ficha ID</th>
                        <th>Colaborador</th>
                        <th>Contacto Interno</th>
                        <th>Rol Asignado</th>
                        <th class="text-center pe-4">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var emp in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">#@emp.IdEmpleado</td>
                                <td>
                                    <div class="fw-bold text-dark" style="font-size: 16px;">@emp.PnombreEmp @emp.Appaterno</div>
                                    <small class="text-muted">@emp.CorreoEmp</small>
                                </td>
                                <td>
                                    <i class="fas fa-phone-alt text-muted me-1 small"></i> @(emp.TelefonoEmp != 0 ? emp.TelefonoEmp.ToString() : "Sin Teléfono")
                                </td>
                                <td>
                                    @switch (emp.IdRolUsuario)
                                    {
                                        case 1:
                                            <span class="badge bg-danger p-2">Gerente General</span>
                                            break;
                                        case 2:

                                            <span class="badge bg-warning text-dark p-2">Administración</span>
                                            break;
                                        case 3:

                                            <span class="badge bg-success p-2">Producción / Calidad</span>
                                            break;
                                        case 4:

                                            <span class="badge bg-info text-dark p-2">Encargado Compras</span>
                                            break;
                                        case 5:

                                            <span class="badge bg-secondary p-2">Encargado Ventas</span>
                                            break;
                                        case 6:

                                            <span class="badge bg-dark p-2">Jefe de Despacho</span>
                                            break;
                                        case 7:

                                            <span class="badge bg-primary p-2"><i class="fas fa-bicycle me-1"></i> Transportista</span>
                                            break;
                                        default:

                                            <span class="badge bg-light text-dark p-2">Personal Externo</span>
                                            break;
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <div class="btn-group shadow-sm">
                                        <button type="button" class="btn btn-sm btn-outline-warning"
                                                onclick="solicitarAutorizacion(@emp.IdEmpleado, 'Editar')">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                onclick="solicitarAutorizacion(@emp.IdEmpleado, 'Eliminar')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fas fa-users-slash fa-3x mb-3 text-muted opacity-50"></i>
                                <p class="h5 mb-0">No se registran empleados contratados en el sistema.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalAutorizar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 15px;">
            <div class="modal-header bg-dark text-white" style="border-radius: 15px 15px 0 0;">
                <h5 class="modal-title fw-bold" id="modalTitulo"><i class="fas fa-shield-alt text-warning me-2"></i>Requiere Autorización de Gerencia</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <p class="text-muted small">Para realizar acciones sobre las fichas de personal, por favor confirme sus credenciales de acceso de nivel 1 (Gerente General).</p>

                <div class="mb-3">
                    <label class="form-label fw-bold text-muted">Nombre de Usuario Gerente</label>
                    <input type="text" id="txtUserGerente" class="form-control" placeholder="Ej: admin_veguita" style="padding: 10px;" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted">Contraseña de Seguridad</label>
                    <input type="password" id="txtPassGerente" class="form-control" style="padding: 10px;" />
                </div>
                <div id="alertErrorGerente" class="alert alert-danger d-none small">
                    <i class="fas fa-exclamation-circle me-1"></i> Credenciales de gerencia inválidas o insuficientes.
                </div>
            </div>
            <div class="modal-footer bg-light" style="border-radius: 0 0 15px 15px;">
                <input type="hidden" id="hdnIdEmpleado" />
                <input type="hidden" id="hdnAccion" />
                <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-dark rounded-pill fw-bold px-4" onclick="ejecutarAccionAutorizada()">
                    <i class="fas fa-unlock-alt me-1 text-warning"></i> Validar y Proceder
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let modalBootstrap = null;

        document.addEventListener("DOMContentLoaded", function() {
            modalBootstrap = new bootstrap.Modal(document.getElementById('modalAutorizar'));
        });

        function solicitarAutorizacion(idEmpleado, accion) {
            document.getElementById('hdnIdEmpleado').value = idEmpleado;
            document.getElementById('hdnAccion').value = accion;
            document.getElementById('txtUserGerente').value = "";
            document.getElementById('txtPassGerente').value = "";
            document.getElementById('alertErrorGerente').classList.add('d-none');

            // Cambiar textos según la acción
            document.getElementById('modalTitulo').innerHTML = accion === 'Editar'
                ? '<i class="fas fa-edit text-warning me-2"></i>Autorizar Modificación Laboral'
                : '<i class="fas fa-trash text-danger me-2"></i>Autorizar Rescisión de Contrato';

            modalBootstrap.show();
        }

        function ejecutarAccionAutorizada() {
            const user = document.getElementById('txtUserGerente').value;
            const pass = document.getElementById('txtPassGerente').value;
            const idEmp = document.getElementById('hdnIdEmpleado').value;
            const accion = document.getElementById('hdnAccion').value;

            if(user.trim() === "" || pass.trim() === "") {
                alert("Por favor, ingrese el usuario y contraseña del Gerente.");
                return;
            }

            // Llamada AJAX nativa para validar las credenciales en el backend sin recargar
            fetch('/Empleados/ValidarPermisoGerente', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `user=${encodeURIComponent(user)}&pass=${encodeURIComponent(pass)}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.autorizado) {
                    modalBootstrap.hide();
                    if (accion === 'Editar') {
                        // Redirige a la pantalla de edición pasándole el ID
                        window.location.href = `/Empleados/Editar/${idEmp}`;
                    } else if (accion === 'Eliminar') {
                        if (confirm("¿Está completamente seguro de eliminar esta ficha de empleado? Esta acción es irreversible.")) {
                            window.location.href = `/Empleados/Eliminar/${idEmp}`;
                        }
                    }
                } else {
                    document.getElementById('alertErrorGerente').classList.remove('d-none');
                }
            })
            .catch(error => {
                console.error("Error en la validación:", error);
                alert("Ocurrió un error al conectar con la base de datos de Oracle Cloud.");
            });
        }
    </script>
}