@model IEnumerable<LaVeguita.Entities.Despacho>

@{
    ViewData["Title"] = "Gestión de Logística";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-0">
                <i class="fas fa-clipboard-list text-success me-2"></i>Panel de Control Logístico
            </h2>
            <p class="text-muted">Asignación de despachos y supervisión de flota</p>
        </div>
        <div class="text-end">
            <span class="badge bg-primary rounded-pill px-3 py-2">
                @Model.Count() Pedidos Totales
            </span>
        </div>
    </div>

    @* CONTENEDOR DE ALERTAS DE ÉXITO O ERROR EN EL BACKEND *@
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm mb-4" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-12">
            <div class="btn-group shadow-sm" role="group">
                <button type="button" class="btn btn-white border active">Todos</button>
                <button type="button" class="btn btn-white border">Por Asignar</button>
                <button type="button" class="btn btn-white border">En Ruta</button>
                <button type="button" class="btn btn-white border text-danger">En Inspección</button>
            </div>
        </div>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="alert alert-light text-center py-5 shadow-sm" style="border-radius: 15px;">
                    <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                    <p class="h5 text-muted">No hay pedidos pendientes de despacho.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm" style="border-radius: 15px; transition: transform 0.2s;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between mb-3">
                                <span class="badge bg-light text-dark border">ID #@item.IdDespacho</span>
                                <span class="badge @(item.PesoTotalKg > 5 ? "bg-warning text-dark" : "bg-info")">
                                    <i class="fas @(item.PesoTotalKg > 5 ? "fa-shuttle-van" : "fa-bicycle") me-1"></i>
                                    @(item.PesoTotalKg > 5 ? "Triciclo" : "Bicicleta")
                                </span>
                            </div>

                            <h5 class="fw-bold mb-1">Orden de Venta: @item.IdVenta</h5>
                            <p class="text-muted small mb-3">Estado: <span class="text-primary fw-bold">@item.EstadoPedido</span></p>

                            <div class="bg-light p-3 rounded-3 mb-4">
                                <div class="row text-center">
                                    <div class="col-6 border-end">
                                        <small class="text-muted d-block">Peso</small>
                                        <span class="fw-bold">@item.PesoTotalKg kg</span>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted d-block">Distancia</small>
                                        <span class="fw-bold">@item.KmObtenidos km</span>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-2">
                                <div class="col-6">
                                    <button type="button" class="btn btn-outline-success w-100 rounded-pill fw-bold btn-sm">
                                        <i class="fas fa-eye me-1"></i> Ver
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button type="button" class="btn btn-primary w-100 rounded-pill fw-bold btn-sm shadow-sm"
                                            data-bs-toggle="modal" data-bs-target="#modalAsignar_@item.IdVenta">
                                        <i class="fas fa-user-tag me-1"></i> Asignar
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* MODAL REESTRUCTURADO Y CORREGIDO PARA CADA TARJETA *@
                    <div class="modal fade" id="modalAsignar_@item.IdVenta" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content" style="border-radius: 15px;">
                                <div class="modal-header bg-success text-white" style="border-radius: 15px 15px 0 0;">
                                    <h5 class="modal-title fw-bold"><i class="fas fa-truck-loading me-2"></i>Asignar Despacho #@item.IdVenta</h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>

                                <form asp-controller="Logistica" asp-action="ConfirmarAsignacion" method="post">
                                    <div class="modal-body p-4">
                                        <input type="hidden" name="IdVenta" value="@item.IdVenta" />
                                        <input type="hidden" name="PesoTotalKg" value="@item.PesoTotalKg" />
                                        <input type="hidden" name="KmObtenidos" value="@item.KmObtenidos" />

                                        <div class="alert alert-info small mb-4">
                                            <strong><i class="fas fa-info-circle me-1"></i>Regla de Negocio:</strong>
                                            Este pedido pesa <strong>@item.PesoTotalKg kg</strong>.
                                            @(item.PesoTotalKg <= 5 ? "Se recomienda asignar BICICLETA." : "Debe asignar TRICICLO (Capacidad 50kg).")
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-bold text-muted">Seleccionar Transportista</label>
                                            <select name="IdEmpleado" class="form-select" required>
                                                <option value="">-- Elija un Conductor --</option>
                                                @if (ViewBag.Transportistas != null)
                                                {
                                                    // Casteamos explícitamente a List<LaVeguita.Entities.Empleado> para que reconozca tus propiedades
                                                    foreach (LaVeguita.Entities.Empleado emp in (List<LaVeguita.Entities.Empleado>)ViewBag.Transportistas)
                                                    {
                                                        <option value="@emp.IdEmpleado">@emp.PnombreEmp @emp.Appaterno</option>
                                                    }
                                                }
                                            </select>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-bold text-muted">Seleccionar Vehículo</label>
                                            <select name="IdTransporte" class="form-select" required>
                                                <option value="">-- Elija Bici o Triciclo --</option>
                                                @if (ViewBag.Vehiculos != null)
                                                {
                                                    foreach (var veh in ViewBag.Vehiculos)
                                                    {
                                                        <option value="@veh.IdTransporte">@veh.TipoMovil - @veh.Serial (Max: @veh.CapMaxKg kg)</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="modal-footer bg-light" style="border-radius: 0 0 15px 15px;">
                                        <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                                        <button type="submit" class="btn btn-success rounded-pill fw-bold px-4">
                                            <i class="fas fa-check-circle me-1"></i> Confirmar Ruta
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                </div>
            }
        }
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
    }

    .btn-white {
        background: white;
        color: #555;
    }

        .btn-white.active {
            background: #2ecc71;
            color: white;
            border-color: #2ecc71;
        }
</style>