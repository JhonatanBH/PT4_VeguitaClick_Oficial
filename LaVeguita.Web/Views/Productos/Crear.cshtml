@model LaVeguita.Entities.Producto
@{
    ViewData["Title"] = "Nuevo Producto";
}

<div style="max-width: 800px; margin: 20px auto; background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
    <h2 style="color: #2c3e50; border-bottom: 2px solid #2ecc71; padding-bottom: 10px;">🍎 Registrar Producto</h2>
    
    <form asp-action="Crear" method="post" style="margin-top: 20px;">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
            
            <div>
                <label style="display:block; font-weight:bold;">Nombre</label>
                <input asp-for="NomProducto"
                       onkeypress="return validarSinTildes(event)"
                       style="width:100%; padding:8px; border:1px solid #ddd; border-radius:5px;" required />
            </div>
            
            <div>
                <label style="display:block; font-weight:bold;">Precio Unitario</label>
                <input asp-for="PrecioUnd" type="number" step="0.01" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:5px;" required />
            </div>

            <div>
                <label style="display:block; font-weight:bold;">Stock Actual</label>
                <input asp-for="StockActual" type="number" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:5px;" required />
            </div>
            <div>
                <label style="display:block; font-weight:bold;">Peso Estimado (kg)</label>
                <input asp-for="PesoUnitEstimado" type="number" step="0.01" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:5px;" />
            </div>

            <div>
                <label style="display:block; font-weight:bold;">Categoría (Tipo)</label>
                <select asp-for="IdTipoProducto" class="form-control" style="width:100%; padding:8px;" required
                        asp-items="@(new SelectList(ViewBag.Tipos, "IdTipoProducto", "NomTipo"))">
                    <option value="">-- Seleccione Categoría --</option>
                </select>
            </div>
            <div>
                <label style="display:block; font-weight:bold;">Proveedor</label>
                <select asp-for="IdProveedor" class="form-control" style="width:100%; padding:8px;"
                        asp-items="@(new SelectList(ViewBag.Proveedores, "IdProveedor", "NomProveedor"))">
                    <option value="0">-- Ninguno / Sin Proveedor --</option>
                </select>
            </div>

            <div>
                <label style="display:block; font-weight:bold;">Calidad</label>
                <select asp-for="IdCalidad" class="form-control" style="width:100%; padding:8px;"
                        asp-items="@(new SelectList(ViewBag.Calidades, "IdCalidad", "NomCalidad"))">
                    <option value="0">-- Ninguna / Estándar --</option>
                </select>
            </div>
            <div>
                <label style="display:block; font-weight:bold;">¿Es Orgánico?</label>
                <select asp-for="EsOrganico" style="width:100%; padding:8px; border:1px solid #ddd; border-radius:5px;">
                    <option value="S">Sí</option>
                    <option value="N">No</option>
                </select>
            </div>
        </div>

        <div style="margin-top:20px;">
            <label style="display:block; font-weight:bold;">Descripción</label>
            <textarea asp-for="Descripcion"
                      onkeypress="return validarSinTildes(event)"
                      style="width:100%; padding:8px; border:1px solid #ddd; border-radius:5px;" rows="2" placeholder="Ej: Manzanas rojas de exportacion..."></textarea>
        </div>

        <input type="hidden" asp-for="Packing" value="Estándar" />
        <input type="hidden" asp-for="StockMin" value="5" />
        <input type="hidden" asp-for="StockMax" value="500" />

        <div style="margin-top: 30px; display: flex; gap: 10px;">
            <button type="submit" style="background:#2ecc71; color:white; border:none; padding:12px 25px; border-radius:8px; cursor:pointer; font-weight:bold; transition: 0.3s;">
                💾 Guardar Producto
            </button>
            <a asp-action="Index" style="background:#95a5a6; color:white; padding:12px 25px; border-radius:8px; text-decoration:none; font-weight:bold;">
                ❌ Cancelar
            </a>
        </div>
    </form>
</div>