@model IEnumerable<LaVeguita.Entities.Producto>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Gestion de Inventario";
    // Rescatamos el rol directamente desde la sesion activa
    int? rol = HttpContextAccessor.HttpContext.Session.GetInt32("RolUsuario");
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
    <h2 style="color: #2c3e50; margin: 0; font-size: 24px;">🍎 Inventario de Productos</h2>

    @* RESTRICCION: Solo Gerente (1) o Administracion (2) pueden crear nuevos productos *@
    @if (rol == 1 || rol == 2)
    {
        <a asp-action="Crear" asp-controller="Productos" style="background-color: #2ecc71; color: white; text-decoration: none; padding: 12px 20px; border-radius: 8px; font-weight: bold; transition: 0.3s; box-shadow: 0 4px 6px rgba(46, 204, 113, 0.2);">
            + Agregar Nuevo Producto
        </a>
    }
</div>

<div style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; background: white; border-radius: 10px; overflow: hidden;">
        <thead>
            <tr style="background-color: #2c3e50; color: white; text-align: left;">
                <th style="padding: 15px;">ID</th>
                <th style="padding: 15px;">Producto</th>
                <th style="padding: 15px;">Tipo</th>
                <th style="padding: 15px;">Precio</th>
                <th style="padding: 15px;">Stock Actual</th>
                <th style="padding: 15px; text-align: center;">Organico</th>
                @* Si es operador basico, la columna de acciones cambia de nombre a una vista informativa *@
                <th style="padding: 15px; text-align: center;">@(rol == 1 || rol == 2 ? "Acciones" : "Estado")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr style="border-bottom: 1px solid #eee; transition: 0.2s;">
                        <td style="padding: 15px; font-weight: bold; color: #7f8c8d;">#@item.IdProducto</td>
                        <td style="padding: 15px;">
                            <span style="font-weight: 600; color: #2c3e50; font-size: 16px;">@item.NomProducto</span><br />
                            <small style="color: #95a5a6;">@item.Descripcion</small>
                        </td>
                        <td style="padding: 15px;">
                            <span style="background: #e8f4fd; color: #2980b9; padding: 5px 10px; border-radius: 20px; font-size: 12px; font-weight: bold; text-transform: uppercase;">
                                @item.NomTipo
                            </span>
                        </td>
                        <td style="padding: 15px; font-weight: bold; color: #27ae60;">
                            $@item.PrecioUnd.ToString("N0")
                        </td>
                        <td style="padding: 15px;">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span style="font-size: 16px; font-weight: bold; color: @(item.StockActual <= item.StockMin ? "#e74c3c" : "#2c3e50");">
                                    @item.StockActual
                                </span>
                                @if (item.StockActual <= item.StockMin)
                                {
                                    <span style="background: #fdeaea; color: #e74c3c; padding: 2px 6px; border-radius: 4px; font-size: 10px; font-weight: bold;">STOCK CRITICO</span>
                                }
                            </div>
                            <small style="color: #bdc3c7;">Min: @item.StockMin | Max: @item.StockMax</small>
                        </td>
                        <td style="padding: 15px; text-align: center; font-size: 20px;">
                            @(item.EsOrganico == "S" ? "🌿" : "❌")
                        </td>
                        <td style="padding: 15px; text-align: center;">
                            @* RESTRICCION: Muestra botones CRUD solo a roles administrativos *@
                            @if (rol == 1 || rol == 2)
                            {
                                <a asp-action="Editar" asp-route-id="@item.IdProducto" class="btn btn-warning btn-sm">
                                    ✏️ Editar
                                </a>
                                <a href="javascript:void(0);" onclick="confirmarEliminar(@item.IdProducto, '@item.NomProducto')" style="text-decoration: none; margin-left: 10px;" title="Eliminar">🗑️</a>
                            }
                            else
                            {
                                @* Mensaje visual de Solo Lectura para Produccion y Ventas *@
                                <span class="badge bg-light text-secondary border small"><i class="fas fa-eye me-1"></i> Solo Lectura</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" style="padding: 40px; text-align: center; color: #bdc3c7;">
                        <div style="font-size: 40px; margin-bottom: 10px;">📦</div>
                        <p>No hay productos en el inventario.</p>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


@section Scripts {
    <script>
        function confirmarEliminar(idProducto, nombreProducto) {
            Swal.fire({
                title: '¿Eliminar Producto?',
                text: '¿Está seguro de eliminar "' + nombreProducto + '"? Esta acción lo dará de baja del catálogo.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e74c3c', // Rojo eliminar
                cancelButtonColor: '#95a5a6',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Redirige al método del controlador que elimina
                    window.location.href = `/Productos/Eliminar/${idProducto}`;
                }
            });
        }
    </script>
}
