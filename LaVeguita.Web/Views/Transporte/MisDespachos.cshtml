@model IEnumerable<LaVeguita.Entities.Despacho>

@{
    ViewData["Title"] = "Mis Entregas";
    // Rescatamos datos de la sesión para el cálculo
    string tipoVehiculo = Context.Session.GetString("TipoVehiculo") ?? "BICICLETA";
    int velocidad = (tipoVehiculo == "BICICLETA") ? 15 : 10;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold"><i class="fas fa-shipping-fast text-success me-2"></i> Mis Despachos Pendientes</h2>
            <p class="text-muted">Vehículo actual: <strong>@tipoVehiculo</strong> (@velocidad km/h)</p>
        </div>
        <span class="badge bg-primary">@Model.Count() pedidos por entregar</span>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-pill shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            // CÁLCULO DE TIEMPO ESTIMADO (Caso 4)
            // Tiempo = (Distancia / Velocidad) * 60 minutos
            decimal tiempoHoras = item.KmObtenidos / (decimal)velocidad;
            int tiempoMinutos = (int)Math.Round(tiempoHoras * 60);

            <div class="col-12 col-md-6 col-lg-4 mb-4">
                <div class="card h-100 border-0 shadow-sm" style="border-radius: 15px;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge bg-light text-success border border-success">Orden #@item.IdVenta</span>
                            <span class="badge bg-info text-dark">@tiempoMinutos min aprox.</span>
                        </div>

                        <h5 class="card-title fw-bold mb-3">Envío ID: @item.IdDespacho</h5>
                        
                        <div class="bg-light p-3 rounded-3 mb-4">
                            <div class="row text-center">
                                <div class="col-6 border-end">
                                    <p class="mb-0 small text-muted">Peso Carga</p>
                                    <span class="fw-bold text-dark">@item.PesoTotalKg kg</span>
                                </div>
                                <div class="col-6">
                                    <p class="mb-0 small text-muted">Distancia</p>
                                    <span class="fw-bold text-dark">@item.KmObtenidos km</span>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <a asp-controller="Transporte" asp-action="MarcarEntregado" asp-route-id="@item.IdDespacho"
                                   class="btn btn-success fw-bold rounded-pill py-2 shadow-sm">
                                <i class="fas fa-check-circle me-2"></i> Confirmar Entrega
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>