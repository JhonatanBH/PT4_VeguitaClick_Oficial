@model IEnumerable<LaVeguita.Entities.Transporte>

@{
    ViewData["Title"] = "Check-in de Vehículo";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 text-center mb-4">
            <h1 class="display-6 fw-bold text-success">¡Hola, @Context.Session.GetString("UsuarioNombre")!</h1>
            <p class="lead text-muted">Selecciona el móvil electromóvil que utilizarás en tu hoja de ruta hoy.</p>
            <hr class="w-25 mx-auto border-success opacity-75" style="border-width: 3px;">
        </div>
    </div>

    <div class="row justify-content-center g-4">
        @foreach (var movil in Model)
        {
            bool esLiviano = movil.CapMaxKg <= 5; // Determina el tipo de rango operativo

            <div class="col-12 col-md-6 col-lg-5">
                <div class="card h-100 shadow-sm border-0 transition-hover" style="border-radius: 25px; overflow: hidden; border-top: 5px solid @(esLiviano ? "#198754" : "#ffc107") !important;">
                    <div class="card-body p-4 text-center">

                        <!-- REGLA DE ICONOS SEGÚN ELECTROMOVILIDAD -->
                        <div class="mb-4 mt-2">
                            @if (movil.TipoMovil.ToUpper().Contains("BICI") || esLiviano)
                            {
                                <i class="fas fa-bicycle fa-5x text-success"></i>
                            }
                            else
                            {
                                <i class="fas fa-truck-ramp-box fa-5x text-warning"></i>
                            }
                        </div>

                        <h3 class="fw-bold text-dark m-0">@movil.TipoMovil</h3>
                        <small class="text-muted d-block mb-3">N° Serie: <span class="font-monospace fw-bold">@movil.Serial</span></small>

                        <!-- BADGE OPERACIONAL: Demuestra consistencia de la regla a la comisión -->
                        <div class="mb-4">
                            @if (esLiviano)
                            {
                                <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill border border-success-subtle">
                                    <i class="fas fa-bolt me-1"></i> Rango: Pedidos Livianos (&lt; 5 kg)
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning-subtle text-warning-emphasis px-3 py-2 rounded-pill border border-warning-subtle">
                                    <i class="fas fa-boxes-packing me-1"></i> Rango: Alta Carga (&ge; 5 kg)
                                </span>
                            }
                        </div>

                        <!-- INDICADORES MAESTROS DE ORACLE -->
                        <div class="row bg-light rounded-4 p-3 mb-4 mx-1 border">
                            <div class="col-6 border-end text-center">
                                <small class="d-block text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">Capacidad Máxima</small>
                                <span class="fw-bold fs-5 text-dark">@movil.CapMaxKg Kg</span>
                            </div>
                            <div class="col-6 text-center">
                                <small class="d-block text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">Código Móvil</small>
                                <span class="fw-bold fs-5 text-secondary">#@movil.IdTransporte</span>
                            </div>
                        </div>

                        <!-- FORMULARIO DE INICIO DE TURNO -->
                        <form asp-action="IniciarTurno" method="post" class="form-checkin">
                            <input type="hidden" name="idTransporte" value="@movil.IdTransporte" />
                            <input type="hidden" name="tipoVehiculo" value="@movil.TipoMovil" />
                            <input type="hidden" name="capMax" value="@movil.CapMaxKg" />

                            <button type="submit" class="btn @(esLiviano ? "btn-success" : "btn-warning text-dark") btn-lg w-100 rounded-pill py-3 shadow-sm fw-bold fs-6 style-btn">
                                <i class="fas fa-key me-2"></i>CONFIRMAR APERTURA DE RUTA
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 2.5rem rgba(0,0,0,.08) !important;
        }

    .style-btn {
        transition: all 0.2s ease;
    }

        .style-btn:hover {
            transform: scale(1.02);
            letter-spacing: 0.5px;
        }
</style>