@model IEnumerable<LaVeguita.Entities.Transporte>

@{
    ViewData["Title"] = "Check-in de Vehículo";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 text-center mb-5">
            <h1 class="display-5 fw-bold text-success">Hola, @Context.Session.GetString("UsuarioNombre")</h1>
            <p class="lead text-muted">Selecciona el móvil que utilizarás en tu ruta de hoy.</p>
            <hr class="w-25 mx-auto border-success opacity-75">
        </div>
    </div>

    <div class="row justify-content-center g-4">
        @foreach (var movil in Model)
        {
            <div class="col-12 col-md-6 col-lg-5">
                <div class="card h-100 shadow-sm border-0 transition-hover" style="border-radius: 25px; overflow: hidden;">
                    <div class="card-body p-5 text-center">
                        <div class="mb-4">
                            @if (movil.TipoMovil.ToUpper().Contains("BICI"))
                            {
                                <i class="fas fa-bicycle fa-5x text-success"></i>
                            }
                            else
                            {
                                <i class="fas fa-motorcycle fa-5x text-success"></i>
                            }
                        </div>

                        <h3 class="fw-bold">@movil.TipoMovil</h3>
                        <p class="text-muted mb-4">Número de Serie: <span class="fw-bold">@movil.Serial</span></p>

                        <div class="row bg-light rounded-4 p-3 mb-4 mx-1">
                            <div class="col-6 border-end text-center">
                                <small class="d-block text-muted text-uppercase">Capacidad</small>
                                <span class="fw-bold fs-5">@movil.CapMaxKg Kg</span>
                            </div>
                            <div class="col-6 text-center">
                                <small class="d-block text-muted text-uppercase">ID Móvil</small>
                                <span class="fw-bold fs-5">#@movil.IdTransporte</span>
                            </div>
                        </div>

                        <form asp-action="IniciarTurno" method="post">
                            <input type="hidden" name="idTransporte" value="@movil.IdTransporte" />
                            <input type="hidden" name="tipoVehiculo" value="@movil.TipoMovil" />
                            <input type="hidden" name="capMax" value="@movil.CapMaxKg" />
                            
                            <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill py-3 shadow-sm fw-bold">
                                SELECCIONAR ESTE VEHÍCULO
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.3s ease, shadow 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-10px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
        }
</style>
