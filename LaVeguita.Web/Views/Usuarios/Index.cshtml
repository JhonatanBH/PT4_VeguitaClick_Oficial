@model IEnumerable<LaVeguita.Entities.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container-card shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold"><i class="fas fa-users-cog text-success me-2"></i>Gestión de Usuarios</h2>
        <a asp-action="Crear" class="btn btn-success px-4 fw-bold shadow-sm">
            <i class="fas fa-user-plus me-1"></i> Nuevo Usuario
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th class="ps-3">ID</th>
                    <th>Usuario</th>
                    <th>Contacto</th>
                    <th>Rol</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3 fw-bold text-muted">#@item.IdUsuario</td>
                        <td>
                            <div class="fw-bold">@item.NombreUser</div>
                            <small class="text-muted">@item.CorreoUsu</small>
                        </td>
                        <td>
                            <i class="fas fa-phone-alt me-1 text-muted small"></i> @item.Fono
                        </td>
                        <td>
                            <span class="badge @(item.IdRolUsuario == 1 ? "bg-danger" : "bg-info text-dark") p-2" style="min-width: 100px;">
                                @item.NombreRol
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group shadow-sm">
                                <a asp-action="Editar" asp-route-id="@item.IdUsuario" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit"></i>
                                </a>
                                
                                <form asp-action="Eliminar" method="post" style="display:inline;"
                                      onsubmit="return confirm('¿Realmente deseas eliminar a @item.NombreUser?')">
                                    <input type="hidden" name="idUsuario" value="@item.IdUsuario" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>