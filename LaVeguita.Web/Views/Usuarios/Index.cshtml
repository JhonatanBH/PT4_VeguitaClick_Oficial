@model IEnumerable<LaVeguita.Entities.Usuario>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div style="background: white; padding: 20px; border-radius: 8px; border: 1px solid #eee; margin-bottom: 30px;">
    <h3 style="margin-top:0; color: #2c3e50;">+ Registrar Nuevo Usuario</h3>
    
    <form asp-controller="Usuarios" asp-action="Crear" method="post" style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">
        
        <div style="display: flex; flex-direction: column;">
            <label style="font-size: 12px; color: #7f8c8d;">Nombre de Usuario</label>
            <input type="text" name="NombreUser" required style="padding: 10px; border: 1px solid #ccc; border-radius: 4px; width: 180px;" />
        </div>

        <div style="display: flex; flex-direction: column;">
            <label style="font-size: 12px; color: #7f8c8d;">Contraseña</label>
            <input type="password" name="Contrasena" required style="padding: 10px; border: 1px solid #ccc; border-radius: 4px; width: 130px;" />
        </div>

        <div style="display: flex; flex-direction: column;">
            <label style="font-size: 12px; color: #7f8c8d;">Correo</label>
            <input type="email" name="CorreoUsu" style="padding: 10px; border: 1px solid #ccc; border-radius: 4px; width: 180px;" />
        </div>

        <div style="display: flex; flex-direction: column;">
            <label style="font-size: 12px; color: #7f8c8d;">Teléfono</label>
            <input type="number" name="Fono" required style="padding: 10px; border: 1px solid #ccc; border-radius: 4px; width: 130px;" />
        </div>

        <input type="hidden" name="IdRolUsuario" value="2" />
        <input type="hidden" name="IdDireccion" value="100" />

        <button type="submit" style="background-color: #2ecc71; color: white; border: none; padding: 12px 25px; border-radius: 5px; cursor: pointer; font-weight: bold; transition: 0.3s;">
            Guardar en Oracle
        </button>
    </form>
</div>

<table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
    <thead>
        <tr style="background-color: #2c3e50; color: white; text-align: left;">
            <th style="padding: 12px; border-bottom: 2px solid #ddd;">ID</th>
            <th style="padding: 12px; border-bottom: 2px solid #ddd;">Nombre</th>
            <th style="padding: 12px; border-bottom: 2px solid #ddd;">Correo</th>
            <th style="padding: 12px; border-bottom: 2px solid #ddd;">Teléfono</th>
            <th style="padding: 12px; border-bottom: 2px solid #ddd;">ID Rol</th>
            <th style="padding: 12px; border-bottom: 2px solid #ddd;">Rol Asignado</th>
            <th style="padding: 12px; border-bottom: 2px solid #ddd; text-align: center;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 12px;">@item.IdUsuario</td>
                <td style="padding: 12px;">@item.NombreUser</td>
                <td style="padding: 12px;">@item.CorreoUsu</td>
                <td style="padding: 12px;">@item.Fono</td>
                
                <td style="padding: 12px;">@item.IdRolUsuario</td>
                <td style="padding: 12px;">
                    <span style="background: #e1f5fe; color: #0288d1; padding: 4px 8px; border-radius: 4px; font-size: 13px; font-weight: bold;">
                        @item.NombreRol
                    </span>
                </td>

                <td style="padding: 12px; text-align: center;">
                    <a asp-action="Editar" asp-route-id="@item.IdUsuario" style="text-decoration: none; color: #f39c12; font-weight: bold; margin-right: 10px;">
                        ✏️ Editar
                    </a>
    
                    <form asp-action="Eliminar" method="post" style="display:inline;" onsubmit="return confirm('¿Seguro que deseas eliminar a @item.NombreUser?')">
                        <input type="hidden" name="idUsuario" value="@item.IdUsuario" />
                        <button type="submit" style="background:none; border:none; color: #e74c3c; cursor:pointer; padding:0; font-family:inherit; font-size:inherit;">
                            🗑️ Borrar
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
